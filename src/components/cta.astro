---
import Link from "./ui/link.astro";
---

<div
  class="bg-black p-8 md:px-20 md:py-24 mt-20 mx-auto max-w-5xl rounded-3xl flex flex-col items-center text-center shadow-2xl border border-zinc-800"
>
  <h2 class="text-white text-4xl md:text-6xl font-bold tracking-tight">
    Ready to engineer your <span class="text-zinc-500 italic">growth?</span>
  </h2>
  <p class="text-slate-400 mt-6 text-lg md:text-xl max-w-2xl font-light">
    Stop managing by feel. Whether you're at the idea level or ready for maturity, 
    let's build the infrastructure your business deserves.
  </p>
  <div class="flex flex-col sm:flex-row gap-4 mt-10">
    <Link 
      href="https://wa.me/2348142243764" 
      style="inverted" 
      class="px-10 py-4 rounded-full uppercase tracking-widest text-sm"
    >
      Chat with a Partner
    </Link>
    <Link 
      href="/contact" 
      style="outline" 
      class="x-10 py-4 rounded-full uppercase tracking-widest text-sm"
    >
      Schedule Advisory
    </Link>
  </div>
</div>