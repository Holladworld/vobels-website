---
const popupTitle = "Free Business Growth Assessment";
const popupDescription = "Not sure how to take your business from small to enterprise?";
const benefits = [
  "Personalized roadmap for your business stage",
  "Identify what's holding you back",
  "Actionable next steps you can implement"
];
const buttonText = "Get My Free Assessment →";
const popupImage = "https://images.unsplash.com/photo-1557804506-669a67965ba0?w=400&h=200&fit=crop";
---

<div id="growth-popup" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden transition-all duration-300">
  <div class="bg-white rounded-2xl max-w-md w-full mx-4 relative shadow-2xl transform transition-all duration-300 scale-95 overflow-hidden">
    
    <!-- Image at the top -->
    <div class="relative h-32 overflow-hidden">
      <img 
        src={popupImage} 
        alt="Business growth" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/20"></div>
    </div>
    
    <!-- Close button -->
    <button id="close-popup" class="absolute top-2 right-2 bg-white/80 hover:bg-white rounded-full p-1 transition-colors z-10">
      <svg class="w-4 h-4 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    
    <!-- Content -->
    <div class="p-6">
      <h3 class="text-xl font-bold text-black text-center mb-2">
        {popupTitle}
      </h3>
      
      <p class="text-zinc-600 text-center text-sm mb-4">
        {popupDescription}
      </p>
      
      <ul class="space-y-2 mb-6">
        {benefits.map((benefit) => (
          <li class="flex items-center gap-2 text-sm text-zinc-700">
            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            {benefit}
          </li>
        ))}
      </ul>
      
      <!-- Form - FIXED -->
      <form id="popup-form" class="space-y-4">
        <input 
          type="email" 
          id="popup-email" 
          name="email"
          required
          placeholder="Enter your business email" 
          class="w-full px-4 py-3 border border-zinc-200 rounded-lg focus:ring-2 focus:ring-black outline-none"
        />
        <button 
          type="submit" 
          id="popup-submit-btn"
          class="w-full bg-black text-white py-3 rounded-lg font-semibold hover:bg-zinc-800 transition-all cursor-pointer"
        >
          {buttonText}
        </button>
      </form>
      
      <p class="text-xs text-zinc-400 text-center mt-4">
        No spam. Get your free assessment.
      </p>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    let popupShown = false;
    const popup = document.getElementById('growth-popup');
    const closeBtn = document.getElementById('close-popup');
    const form = document.getElementById('popup-form');
    const emailInput = document.getElementById('popup-email');
    
    // Check if popup was already shown in this session
    if (sessionStorage.getItem('popupShown')) {
      return;
    }
    
    function showPopup() {
      if (popupShown) return;
      popupShown = true;
      sessionStorage.setItem('popupShown', 'true');
      popup.classList.remove('hidden');
      setTimeout(() => {
        const modalContent = popup.querySelector('.bg-white');
        if (modalContent) {
          modalContent.classList.remove('scale-95');
          modalContent.classList.add('scale-100');
        }
      }, 10);
    }
    
    function closePopup() {
      const modalContent = popup.querySelector('.bg-white');
      if (modalContent) {
        modalContent.classList.remove('scale-100');
        modalContent.classList.add('scale-95');
      }
      setTimeout(() => {
        popup.classList.add('hidden');
      }, 200);
    }
    
    // Show popup after 30 seconds
    const timer = setTimeout(showPopup, 30000);
    
    // Show on scroll (50% of page)
    let scrollTriggered = false;
    window.addEventListener('scroll', function() {
      if (scrollTriggered || popupShown) return;
      const scrollPercent = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
      if (scrollPercent > 0.5) {
        scrollTriggered = true;
        clearTimeout(timer);
        showPopup();
      }
    });
    
    // Close button click
    if (closeBtn) {
      closeBtn.addEventListener('click', closePopup);
    }
    
    // Close when clicking outside
    popup.addEventListener('click', function(e) {
      if (e.target === popup) {
        closePopup();
      }
    });
    
    // Form submission
    if (form) {
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const email = emailInput.value.trim();
        
        if (!email) {
          alert('Please enter your email address');
          return;
        }
        
        // Change button text to show loading
        const submitBtn = document.getElementById('popup-submit-btn');
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = 'Sending...';
        submitBtn.disabled = true;
        
        try {
          const response = await fetch('/api/capture-lead', {
            method: 'POST',
            headers: { 
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ 
              email: email, 
              source: 'growth_popup',
              timestamp: new Date().toISOString()
            })
          });
          
          const result = await response.json();
          
          if (response.ok) {
            // Show success message
            form.innerHTML = `
              <div class="text-center p-4 bg-green-50 rounded-lg">
                <p class="text-green-700 font-semibold">Thank you!</p>
                <p class="text-sm text-green-600 mt-1">Check your email for your free e-book.</p>
              </div>
            `;
            
            // Auto close after 3 seconds
            setTimeout(closePopup, 3000);
          } else {
            throw new Error(result.error || 'Something went wrong');
          }
        } catch (error) {
          console.error('Error:', error);
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;
          alert('Something went wrong. Please try again.');
        }
      });
    }
  })();
</script>