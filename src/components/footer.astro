---
import { Icon } from "astro-icon/components";

const currentYear = new Date().getFullYear();

const socialLinks = [
  { name: "X", url: "https://x.com/vobels_", icon: "bx:bxl-twitter" },
  { name: "Instagram", url: "https://instagram.com/vobels", icon: "bx:bxl-instagram" },
  { name: "TikTok", url: "https://tiktok.com/@vobels", icon: "bx:bxl-tiktok" },
  { name: "GitHub", url: "https://github.com/vobels", icon: "bx:bxl-github" },
  { name: "LinkedIn", url: "https://linkedin.com/company/vobels", icon: "bx:bxl-linkedin" }
];
---

<footer class="my-20">
  <!-- Social Icons Row -->
  <div class="flex justify-center gap-6 mb-6">
    {socialLinks.map((social) => (
      <a
        href={social.url}
        target="_blank"
        rel="noopener noreferrer"
        class="w-10 h-10 bg-zinc-100 rounded-full flex items-center justify-center text-zinc-600 hover:bg-black hover:text-white transition-all hover:scale-110"
        aria-label={social.name}
      >
        <Icon name={social.icon} class="w-5 h-5" />
      </a>
    ))}
  </div>
  
  <!-- Copyright -->
  <p class="text-center text-sm text-zinc-500">
    Copyright © {currentYear} Vobels Limited. All rights reserved.
  </p>
</footer>