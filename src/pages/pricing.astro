---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { Icon } from "astro-icon/components";

// Client journey stages
const stages = [
  {
    id: "startup",
    name: "Startup Launch",
    subtitle: "From Idea to First Customer",
    tagline: "You have a business idea. You need everything built from scratch.",
    price: "Project-Based",
    priceDetail: "One-time fee, tailored to your scope",
    popular: false,
    audience: "Ideal for: First-time founders, new business owners",
    timeline: "2-6 weeks",
    icon: "bx:rocket",  // Fixed: removed bxs-
    features: [
      { name: "Business Idea Validation", included: true },
      { name: "Business Structure Advisory", included: true },
      { name: "CAC Registration & Compliance", included: true },
      { name: "Brand Identity & Positioning", included: true },
      { name: "Professional Website Setup", included: true },
      { name: "Ongoing Support", included: false, note: "Available as add-on" }
    ],
    buttonText: "Start Your Launch",
    buttonLink: "/contact"
  },
  {
    id: "growth",
    name: "Growth Accelerator",
    subtitle: "Scale Your Existing Business",
    tagline: "You already have customers. Now you need systems to grow.",
    price: "Monthly Retainer",
    priceDetail: "Starting at ₦250,000/month",
    popular: true,
    audience: "Ideal for: Established businesses ready to scale",
    timeline: "3-12 months commitment",
    icon: "bx:line-chart",  // Fixed: changed to line-chart
    features: [
      { name: "Brand Audit & Repositioning", included: true },
      { name: "Marketing & Visibility Strategy", included: true },
      { name: "Financial Systems", included: true },
      { name: "Sales Acquisition Systems", included: true },
      { name: "Operational Process Review", included: true },
      { name: "Monthly Strategy Sessions", included: true }
    ],
    buttonText: "Accelerate Growth",
    buttonLink: "/contact"
  },
  {
    id: "enterprise",
    name: "Enterprise Partnership",
    subtitle: "Strategic Business Partnership",
    tagline: "You want a long-term partner to run and scale your business with you.",
    price: "Equity / Revenue Share",
    priceDetail: "Custom arrangement based on mutual value",
    popular: false,
    audience: "Ideal for: High-potential ventures seeking partnership",
    timeline: "Long-term commitment",
    icon: "bx:crown",  // Fixed: removed bxs-
    features: [
      { name: "Ongoing Strategic Advisory", included: true },
      { name: "Financial & Compliance Monitoring", included: true },
      { name: "Regulatory & IP Protection", included: true },
      { name: "Market Entry & Expansion", included: true },
      { name: "Venture Studio Eligibility", included: true },
      { name: "Equity Partnership Option", included: true, highlight: true }
    ],
    buttonText: "Explore Partnership",
    buttonLink: "/contact"
  }
];
---

<Layout title="Pricing & Packages | Vobels Limited">
  <Container>
    <!-- Header -->
    <div class="mt-16 text-center max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-black text-black tracking-tighter">
        Choose Your Path
      </h1>
      <p class="text-xl text-zinc-600 mt-4">
        Every business is at a different stage. Select the engagement model that fits where you are today.
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid md:grid-cols-3 gap-8 mt-16">
      {stages.map((stage) => (
        <div class={`relative rounded-2xl bg-white border ${stage.popular ? 'border-black shadow-2xl md:scale-105' : 'border-zinc-200 shadow-lg'} transition-all hover:shadow-xl hover:-translate-y-1 duration-300`}>
          
          {stage.popular && (
            <div class="absolute top-0 right-0 bg-black text-white text-xs font-bold px-4 py-1 rounded-bl-lg rounded-tr-lg">
              Most Popular
            </div>
          )}
          
          <div class="p-6">
            <!-- Icon -->
            <div class="w-12 h-12 bg-black rounded-full flex items-center justify-center mb-4">
              <Icon name={stage.icon} class="w-6 h-6 text-white" />
            </div>
            
            <h2 class="text-2xl font-bold text-black">
              {stage.name}
            </h2>
            <p class="text-sm text-zinc-500 mt-1">
              {stage.subtitle}
            </p>
            
            <div class="mt-4 pb-4 border-b border-zinc-200">
              <div class="text-3xl font-black text-black">
                {stage.price}
              </div>
              <p class="text-xs text-zinc-500 mt-1">
                {stage.priceDetail}
              </p>
            </div>
            
            <div class="mt-4 space-y-3">
              <div class="flex items-start gap-2">
                <Icon name="bx:bulb" class="w-4 h-4 text-amber-600 mt-0.5" />
                <div>
                  <p class="text-sm font-medium text-black">
                    {stage.tagline}
                  </p>
                </div>
              </div>
              
              <div class="flex items-start gap-2">
                <Icon name="bx:time" class="w-4 h-4 text-blue-600 mt-0.5" />
                <div>
                  <p class="text-sm text-zinc-600">
                    <span class="font-medium">Timeline:</span> {stage.timeline}
                  </p>
                </div>
              </div>
              
              <div class="flex items-start gap-2">
                <Icon name="bx:user" class="w-4 h-4 text-purple-600 mt-0.5" />
                <div>
                  <p class="text-sm text-zinc-600">
                    {stage.audience}
                  </p>
                </div>
              </div>
            </div>
            
            <div class="mt-6">
              <h3 class="text-sm font-bold uppercase tracking-wider text-zinc-500 mb-3">
                What's Included
              </h3>
              <ul class="space-y-2">
                {stage.features.map((feature) => (
                  <li class="flex items-start gap-2">
                    {feature.included ? (
                      <Icon name="bx:check-circle" class="w-4 h-4 text-green-600 mt-0.5" />
                    ) : (
                      <Icon name="bx:x-circle" class="w-4 h-4 text-zinc-400 mt-0.5" />
                    )}
                    <span class={`text-sm ${feature.included ? 'text-zinc-700' : 'text-zinc-400'}`}>
                      {feature.name}
                      {feature.note && <span class="text-xs text-zinc-400 ml-1">({feature.note})</span>}
                      {feature.highlight && <span class="text-xs font-bold text-purple-600 ml-1">★</span>}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
            
            <div class="mt-8">
              <a 
                href={stage.buttonLink}
                class={`block text-center py-3 rounded-lg font-semibold transition-all bg-black text-white hover:bg-zinc-800`}
              >
                {stage.buttonText} →
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Comparison Table -->
    <div class="mt-20">
      <h2 class="text-2xl font-bold text-center mb-8">Which Path Is Right For You?</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse bg-white rounded-xl overflow-hidden border border-zinc-200">
          <thead>
            <tr class="bg-zinc-50">
              <th class="p-4 text-left font-bold text-black">Scenario</th>
              <th class="p-4 text-center font-bold text-black">Startup Launch</th>
              <th class="p-4 text-center font-bold text-black">Growth Accelerator</th>
              <th class="p-4 text-center font-bold text-black">Enterprise Partnership</th>
             </tr>
          </thead>
          <tbody>
            <tr class="border-b border-zinc-200">
              <td class="p-4 font-medium text-black">You have a business idea but nothing else</td>
              <td class="p-4 text-center">
                <Icon name="bx:check-circle" class="w-5 h-5 text-green-600 mx-auto" />
              </td>
              <td class="p-4 text-center">
                <Icon name="bx:x-circle" class="w-5 h-5 text-zinc-400 mx-auto" />
              </td>
              <td class="p-4 text-center">
                <Icon name="bx:x-circle" class="w-5 h-5 text-zinc-400 mx-auto" />
              </td>
            </tr>
            <tr class="border-b border-zinc-200 bg-zinc-50">
              <td class="p-4 font-medium text-black">You already have customers and revenue</td>
              <td class="p-4 text-center">
                <Icon name="bx:x-circle" class="w-5 h-5 text-zinc-400 mx-auto" />
              </td>
              <td class="p-4 text-center">
                <Icon name="bx:check-circle" class="w-5 h-5 text-green-600 mx-auto" />
              </td>
              <td class="p-4 text-center">
                <Icon name="bx:x-circle" class="w-5 h-5 text-zinc-400 mx-auto" />
              </td>
            </tr>
            <tr class="border-b border-zinc-200">
              <td class="p-4 font-medium text-black">You want a long-term strategic partner</td>
              <td class="p-4 text-center">
                <Icon name="bx:x-circle" class="w-5 h-5 text-zinc-400 mx-auto" />
              </td>
              <td class="p-4 text-center">
                <Icon name="bx:x-circle" class="w-5 h-5 text-zinc-400 mx-auto" />
              </td>
              <td class="p-4 text-center">
                <Icon name="bx:check-circle" class="w-5 h-5 text-green-600 mx-auto" />
              </td>
            </tr>
            <tr class="border-b border-zinc-200 bg-zinc-50">
              <td class="p-4 font-medium text-black">Budget flexibility</td>
              <td class="p-4 text-center text-sm text-zinc-600">One-time project fee</td>
              <td class="p-4 text-center text-sm text-zinc-600">Monthly retainer</td>
              <td class="p-4 text-center text-sm text-zinc-600">Equity/Revenue share</td>
            </tr>
            <tr class="border-b border-zinc-200">
              <td class="p-4 font-medium text-black">Time commitment</td>
              <td class="p-4 text-center text-sm text-zinc-600">2-6 weeks</td>
              <td class="p-4 text-center text-sm text-zinc-600">3-12 months</td>
              <td class="p-4 text-center text-sm text-zinc-600">Long-term</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Link to Individual Services -->
    <div class="mt-20 text-center bg-zinc-50 rounded-2xl p-8 border border-zinc-200">
      <h2 class="text-2xl font-bold text-black mb-3">Need Just One Service?</h2>
      <p class="text-zinc-600 mb-6 max-w-2xl mx-auto">
        If you don't need a full package, you can purchase individual services like CAC Registration, 
        Trademark Filing, or Website Development separately.
      </p>
      <a 
        href="/business-pricing" 
        class="inline-block bg-black text-white px-8 py-3 rounded-lg font-semibold hover:bg-zinc-800 transition-all"
      >
        View Individual Services →
      </a>
    </div>

    <!-- FAQ Section -->
    <div class="mt-20 mb-20">
      <h2 class="text-2xl font-bold text-center mb-8">Frequently Asked Questions</h2>
      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <div class="bg-white border border-zinc-200 rounded-xl p-6">
          <div class="w-8 h-8 bg-black rounded-full flex items-center justify-center mb-3">
            <Icon name="bx:help-circle" class="w-4 h-4 text-white" />
          </div>
          <h3 class="font-bold text-black mb-2">How do I know which package is right?</h3>
          <p class="text-sm text-zinc-600">Schedule a free consultation. We'll assess your business and recommend the best path.</p>
        </div>
        <div class="bg-white border border-zinc-200 rounded-xl p-6">
          <div class="w-8 h-8 bg-black rounded-full flex items-center justify-center mb-3">
            <Icon name="bx:transfer" class="w-4 h-4 text-white" />
          </div>
          <h3 class="font-bold text-black mb-2">Can I upgrade or downgrade?</h3>
          <p class="text-sm text-zinc-600">Yes. As your business grows, you can move between packages.</p>
        </div>
        <div class="bg-white border border-zinc-200 rounded-xl p-6">
          <div class="w-8 h-8 bg-black rounded-full flex items-center justify-center mb-3">
            <Icon name="bx:file" class="w-4 h-4 text-white" />
          </div>
          <h3 class="font-bold text-black mb-2">Is there a contract?</h3>
          <p class="text-sm text-zinc-600">Growth Accelerator requires 3-month minimum. Others are flexible.</p>
        </div>
        <div class="bg-white border border-zinc-200 rounded-xl p-6">
          <div class="w-8 h-8 bg-black rounded-full flex items-center justify-center mb-3">
            <Icon name="bx:cog" class="w-4 h-4 text-white" />
          </div>
          <h3 class="font-bold text-black mb-2">Do you offer custom packages?</h3>
          <p class="text-sm text-zinc-600">Yes. Contact us for tailored solutions for your specific needs.</p>
        </div>
      </div>
      
      <div class="text-center mt-8">
        <a href="/contact" class="text-black font-semibold underline underline-offset-4">
          Still have questions? Contact us →
        </a>
      </div>
    </div>
  </Container>
</Layout>