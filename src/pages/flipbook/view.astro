<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Vobels Flipbook | Digital Publication</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="shortcut icon" href="/favicon.svg">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #2c2b28;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            touch-action: pan-x pan-y; /* Enable touch gestures */
        }
        
        .navbar {
            padding: 0.5rem 1rem;
            background: #1f1e1c;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.5rem;
            z-index: 10;
        }
        
        .brand {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: 1rem;
            font-weight: 400;
            color: #e8e5df;
            text-decoration: none;
        }
        
        .nav-links {
            display: flex;
            gap: 0.5rem;
        }
        
        .nav-links a {
            background: transparent;
            color: #a09d96;
            text-decoration: none;
            padding: 0.3rem 0.7rem;
            border-radius: 4px;
            font-size: 0.7rem;
            transition: all 0.2s;
            border: 1px solid #5a5852;
        }
        
        .nav-links a:first-child {
            background: #5a5852;
            color: #e8e5df;
            border: none;
        }
        
        .toolbar {
            display: flex;
            gap: 0.3rem;
            align-items: center;
            flex-wrap: wrap;
            justify-content: center;
        }
        
        .toolbar button {
            background: #3d3c38;
            border: none;
            padding: 0.4rem 0.7rem;
            font-size: 0.7rem;
            font-weight: 450;
            cursor: pointer;
            color: #e8e5df;
            transition: all 0.2s;
            border-radius: 4px;
            touch-action: manipulation;
        }
        
        .toolbar button:active {
            background: #5a5852;
            transform: scale(0.95);
        }
        
        .page-info {
            font-size: 0.7rem;
            color: #a09d96;
            margin: 0 0.3rem;
        }
        
        .zoom-controls {
            display: flex;
            gap: 0.2rem;
        }
        
        .zoom-controls button {
            padding: 0.4rem 0.6rem;
            font-size: 0.7rem;
        }
        
        #flipbook-container {
            flex: 1;
            position: relative;
            overflow: auto;
            background: #2c2b28;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 10px;
            -webkit-overflow-scrolling: touch;
        }
        
        #flipbook {
            background: #e8e5df;
            position: relative;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            transform-origin: center center;
            transition: transform 0.2s ease;
        }
        
        /* Turn.js page styling */
        #flipbook .page {
            background: white;
            box-shadow: 0 0 15px rgba(0,0,0,0.2);
        }
        
        #flipbook .page img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
            pointer-events: none; /* Allow touch events to pass through for turning */
        }
        
        #flipbook .double {
            background: white;
        }
        
        .loading-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #1f1e1c;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 1rem;
            z-index: 100;
        }
        
        .spinner {
            width: 40px;
            height: 40px;
            border: 2px solid #5a5852;
            border-top-color: #e8e5df;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }
        
        @keyframes spin { to { transform: rotate(360deg); } }
        
        .loading-overlay p {
            color: #a09d96;
            font-size: 0.9rem;
        }
        
        .instruction {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.85);
            color: white;
            padding: 8px 16px;
            border-radius: 30px;
            font-size: 0.7rem;
            pointer-events: none;
            z-index: 20;
            opacity: 0;
            transition: opacity 0.3s;
            white-space: nowrap;
            backdrop-filter: blur(10px);
        }
        
        /* Mobile-specific styles */
        @media (max-width: 768px) {
            .navbar {
                padding: 0.5rem;
            }
            
            .brand {
                font-size: 0.9rem;
            }
            
            .toolbar button {
                padding: 0.35rem 0.6rem;
                font-size: 0.65rem;
            }
            
            .page-info {
                font-size: 0.65rem;
            }
            
            .instruction {
                font-size: 0.6rem;
                bottom: 15px;
                white-space: nowrap;
            }
            
            #flipbook-container {
                padding: 5px;
            }
        }
        
        @media (max-width: 480px) {
            .toolbar {
                gap: 0.2rem;
            }
            
            .toolbar button {
                padding: 0.3rem 0.5rem;
                font-size: 0.6rem;
            }
            
            .nav-links a {
                padding: 0.25rem 0.5rem;
                font-size: 0.65rem;
            }
        }
        
        /* Hide scrollbar on mobile but keep functionality */
        @media (max-width: 768px) {
            #flipbook-container::-webkit-scrollbar {
                width: 0;
                background: transparent;
            }
        }
    </style>
</head>
<body>
    <div class="navbar">
        <a href="/" class="brand">Vobels Flipbook</a>
        <div class="nav-links">
            <a href="/flipbook/create">+ New</a>
            <a href="/flipbook/my-books">📚 My Books</a>
        </div>
    </div>
    
    <div class="toolbar">
        <button id="prev-page">← Prev</button>
        <span class="page-info">
            <span id="current-page">1</span> / <span id="total-pages">...</span>
        </span>
        <button id="next-page">Next →</button>
        <button id="fullscreen-btn">Full</button>
        <button id="download-btn">Download</button>
        <button id="share-btn">Share</button>
        <div class="zoom-controls">
            <button id="zoom-out" title="Zoom out">−</button>
            <button id="zoom-reset" title="Reset zoom">Fit</button>
            <button id="zoom-in" title="Zoom in">+</button>
        </div>
    </div>
    
    <div id="flipbook-container">
        <div id="flipbook">
            <div class="loading-overlay">
                <div class="spinner"></div>
                <p>Loading your publication...</p>
            </div>
        </div>
    </div>
    
    <div class="instruction" id="instruction">Swipe or tap edges to flip</div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/turn.js/3/turn.min.js"></script>
    
<script>
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
    
    let pdfDoc = null;
    let pageCount = 0;
    let currentPage = 1;
    let currentBookId = null;
    let pagesData = [];
    let originalWidth = 0;
    let originalHeight = 0;
    let currentScale = 1.0;
    let turnInstance = null;
    let touchStartX = 0;
    let touchEndX = 0;
    let isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
    
    function getBookId() {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get('id');
    }
    
    // Calculate optimal scale for current screen
    function calculateOptimalScale() {
        const container = document.getElementById('flipbook-container');
        const maxWidth = window.innerWidth - (isMobile ? 20 : 60);
        const maxHeight = window.innerHeight - (isMobile ? 180 : 200);
        
        const scaleByWidth = maxWidth / originalWidth;
        const scaleByHeight = maxHeight / originalHeight;
        
        // On mobile, use a more aggressive fit (85% of available space)
        const fitScale = isMobile 
            ? Math.min(scaleByWidth, scaleByHeight, 0.9)
            : Math.min(scaleByWidth, scaleByHeight, 1.2);
        
        return Math.max(fitScale, 0.5);
    }
    
    async function loadPDF() {
        const bookId = getBookId();
        const urlParams = new URLSearchParams(window.location.search);
        const directPdfUrl = urlParams.get('pdf');
        
        console.log("=== FLIPBOOK DEBUG INFO ===");
        console.log("Book ID from URL:", bookId);
        console.log("Is Mobile:", isMobile);
        
        if (directPdfUrl) {
            console.log("Loading direct PDF from:", directPdfUrl);
            try {
                const loadingTask = pdfjsLib.getDocument(directPdfUrl);
                pdfDoc = await loadingTask.promise;
                pageCount = pdfDoc.numPages;
                document.getElementById('total-pages').textContent = pageCount;
                await getAndSetBookDimensions();
                await convertPagesToImages();
                return;
            } catch (error) {
                console.error("Direct PDF error:", error);
                showError(error);
                return;
            }
        }
        
        if (!bookId) {
            console.error("No book ID found in URL");
            document.getElementById('flipbook').innerHTML = `
                <div class="loading-overlay">
                    <p>No publication specified</p>
                    <a href="/flipbook/create" style="color: #8b7e6b; margin-top: 1rem;">Create a flipbook →</a>
                </div>
            `;
            return;
        }
        
        currentBookId = bookId;
        
        try {
            console.log("Fetching from API...");
            const response = await fetch(`/api/flipbook?id=${bookId}`);
            const data = await response.json();
            
            if (data.success && data.pdfUrl) {
                console.log("Loading PDF from URL...");
                const loadingTask = pdfjsLib.getDocument(data.pdfUrl);
                pdfDoc = await loadingTask.promise;
                pageCount = pdfDoc.numPages;
                document.getElementById('total-pages').textContent = pageCount;
                await getAndSetBookDimensions();
                await convertPagesToImages();
            } else {
                throw new Error(data.error || 'Unable to load flipbook');
            }
        } catch (error) {
            console.error("Load error:", error);
            showError(error);
        }
    }
    
    async function getAndSetBookDimensions() {
        const firstPage = await pdfDoc.getPage(1);
        const viewport = firstPage.getViewport({ scale: 1 });
        
        originalWidth = viewport.width;
        originalHeight = viewport.height;
        
        currentScale = calculateOptimalScale();
        
        console.log(`Book dimensions: ${originalWidth}x${originalHeight}, Scale: ${currentScale}, Mobile: ${isMobile}`);
    }
    
    async function convertPagesToImages() {
        const flipbookDiv = document.getElementById('flipbook');
        flipbookDiv.innerHTML = '<div class="loading-overlay"><div class="spinner"></div><p>Preparing the pages...</p></div>';
        
        pagesData = [];
        const renderScale = isMobile ? 1.5 : 2.0; // Lower quality on mobile for performance
        
        for (let i = 1; i <= pageCount; i++) {
            console.log(`Converting page ${i}/${pageCount}...`);
            const page = await pdfDoc.getPage(i);
            const viewport = page.getViewport({ scale: renderScale });
            const canvas = document.createElement('canvas');
            canvas.width = viewport.width;
            canvas.height = viewport.height;
            const context = canvas.getContext('2d');
            
            await page.render({ canvasContext: context, viewport }).promise;
            pagesData.push(canvas.toDataURL('image/jpeg', isMobile ? 0.85 : 0.92));
            
            if (i % 5 === 0 || i === pageCount) {
                flipbookDiv.innerHTML = `<div class="loading-overlay"><div class="spinner"></div><p>Loading page ${i}/${pageCount}...</p></div>`;
            }
        }
        
        console.log(`All ${pageCount} pages converted successfully`);
        createFlipbook();
    }
    
    function createFlipbook() {
        const flipbookDiv = document.getElementById('flipbook');
        
        // Build HTML with proper page divs
        let html = '';
        for (let i = 0; i < pagesData.length; i++) {
            html += `
                <div class="page" style="background: white;">
                    <img src="${pagesData[i]}" style="width: 100%; height: auto; display: block;" alt="Page ${i + 1}">
                </div>
            `;
        }
        flipbookDiv.innerHTML = html;
        
        const displayWidth = originalWidth * currentScale;
        const displayHeight = originalHeight * currentScale;
        
        flipbookDiv.style.width = displayWidth + 'px';
        flipbookDiv.style.height = displayHeight + 'px';
        
        // Initialize turn.js with mobile-friendly settings
        $(flipbookDiv).turn({
            width: displayWidth,
            height: displayHeight,
            autoCenter: true,
            display: 'single',
            acceleration: true,
            gradients: false,
            elevation: isMobile ? 20 : 30,
            when: {
                turned: function(e, page) {
                    currentPage = page;
                    document.getElementById('current-page').textContent = currentPage;
                    updateButtons();
                }
            }
        });
        
        // Add touch/swipe support for mobile
        setupTouchControls(flipbookDiv);
        
        // Add click detection for page edges (works on both desktop and mobile)
        $(flipbookDiv).off('click').on('click', function(e) {
            const width = $(this).width();
            const clickX = e.clientX - $(this).offset().left;
            
            if (clickX < width * 0.25) {
                $(flipbookDiv).turn('previous');
                showInstruction('← Previous page', 800);
            } else if (clickX > width * 0.75) {
                $(flipbookDiv).turn('next');
                showInstruction('Next page →', 800);
            }
        });
        
        centerFlipbook();
        showInstruction(isMobile ? 'Swipe or tap edges to flip' : 'Click left or right edges to flip pages', 2500);
        updateButtons();
        
        turnInstance = flipbookDiv;
        checkAndAddWatermark();
    }
    
    // Setup touch swipe gestures for mobile
    function setupTouchControls(element) {
        let touchStartX = 0;
        let touchEndX = 0;
        let touchStartY = 0;
        let touchEndY = 0;
        
        element.addEventListener('touchstart', function(e) {
            touchStartX = e.changedTouches[0].screenX;
            touchStartY = e.changedTouches[0].screenY;
        }, { passive: false });
        
        element.addEventListener('touchend', function(e) {
            touchEndX = e.changedTouches[0].screenX;
            touchEndY = e.changedTouches[0].screenY;
            handleSwipe();
        });
        
        function handleSwipe() {
            const deltaX = touchEndX - touchStartX;
            const deltaY = touchEndY - touchStartY;
            
            // Horizontal swipe (left/right)
            if (Math.abs(deltaX) > Math.abs(deltaY) && Math.abs(deltaX) > 50) {
                if (deltaX < 0) {
                    // Swipe left - next page
                    $(element).turn('next');
                    showInstruction('Next page →', 500);
                } else {
                    // Swipe right - previous page
                    $(element).turn('previous');
                    showInstruction('← Previous page', 500);
                }
            }
        }
    }
    
    function centerFlipbook() {
        const flipbook = document.getElementById('flipbook');
        const container = document.getElementById('flipbook-container');
        
        if (flipbook && container) {
            const containerRect = container.getBoundingClientRect();
            const flipbookRect = flipbook.getBoundingClientRect();
            
            const scrollLeft = (flipbookRect.width - containerRect.width) / 2;
            const scrollTop = (flipbookRect.height - containerRect.height) / 2;
            
            container.scrollLeft = Math.max(0, scrollLeft);
            container.scrollTop = Math.max(0, scrollTop);
        }
    }
    
    function applyZoom() {
        if (!turnInstance) return;
        
        const displayWidth = originalWidth * currentScale;
        const displayHeight = originalHeight * currentScale;
        
        $(turnInstance).turn('size', displayWidth, displayHeight);
        $(turnInstance).turn('resize');
        
        turnInstance.style.width = displayWidth + 'px';
        turnInstance.style.height = displayHeight + 'px';
        
        document.getElementById('zoom-reset').textContent = Math.round(currentScale * 100) + '%';
        centerFlipbook();
    }
    
    function zoomIn() {
        currentScale = Math.min(currentScale + 0.1, (isMobile ? 1.5 : 2.0));
        applyZoom();
        showInstruction('Zoom: ' + Math.round(currentScale * 100) + '%', 500);
    }
    
    function zoomOut() {
        currentScale = Math.max(currentScale - 0.1, 0.4);
        applyZoom();
        showInstruction('Zoom: ' + Math.round(currentScale * 100) + '%', 500);
    }
    
    function fitToScreen() {
        currentScale = calculateOptimalScale();
        applyZoom();
        showInstruction(isMobile ? 'Fit to screen' : 'Fit: ' + Math.round(currentScale * 100) + '%', 500);
    }
    
    function updateButtons() {
        const prevBtn = document.getElementById('prev-page');
        const nextBtn = document.getElementById('next-page');
        if (prevBtn) prevBtn.disabled = currentPage <= 1;
        if (nextBtn) nextBtn.disabled = currentPage >= pageCount;
    }
    
    function goToPrevPage() { 
        if (currentPage > 1 && turnInstance) {
            $(turnInstance).turn('previous');
            showInstruction('← Previous page', 500);
        }
    }
    
    function goToNextPage() { 
        if (currentPage < pageCount && turnInstance) {
            $(turnInstance).turn('next');
            showInstruction('Next page →', 500);
        }
    }
    
    function toggleFullscreen() { 
        const container = document.getElementById('flipbook-container');
        if (!document.fullscreenElement) {
            container.requestFullscreen().then(() => {
                setTimeout(() => {
                    fitToScreen();
                    centerFlipbook();
                }, 100);
            });
        } else {
            document.exitFullscreen();
        }
    }
    
    function downloadPDF() { 
        if (currentBookId) {
            window.location.href = `/api/flipbook?id=${currentBookId}&download=true`;
        } else {
            alert('Download not available for this PDF');
        }
    }
    
    function copyShareLink() {
        navigator.clipboard.writeText(window.location.href);
        showInstruction('✓ Link copied!', 1500);
    }
    
    function showInstruction(message, duration) {
        const inst = document.getElementById('instruction');
        inst.textContent = message;
        inst.style.opacity = '1';
        setTimeout(() => {
            inst.style.opacity = '0';
        }, duration);
    }
    
    async function checkAndAddWatermark() {
        const bookId = getBookId();
        if (!bookId) return;
    
        try {
            const response = await fetch(`/api/check-flipbook-plan?id=${bookId}`);
            const data = await response.json();
    
            if (!data.isPremium) {
                const watermark = document.createElement('div');
                watermark.id = 'vobels-watermark';
                watermark.innerHTML = `
                    <div style="
                        position: fixed;
                        bottom: 10px;
                        right: 10px;
                        z-index: 9999;
                        opacity: 0.3;
                        font-family: 'Playfair Display', serif;
                        font-size: ${isMobile ? '8px' : '11px'};
                        color: #888;
                        background: rgba(0,0,0,0.05);
                        padding: 4px 10px;
                        border-radius: 20px;
                        pointer-events: none;
                    ">
                        Vobels Flipbook
                    </div>
                `;
                document.body.appendChild(watermark);
            }
        } catch (err) {
            console.error('Watermark check failed:', err);
        }
    }
    
    function showError(error) {
        document.getElementById('flipbook').innerHTML = `
            <div class="loading-overlay">
                <p>Unable to load this publication</p>
                <p style="font-size: 0.8rem; margin-top: 10px;">${error.message}</p>
                <a href="/flipbook/create" style="color: #8b7e6b; margin-top: 1rem;">Create new flipbook →</a>
            </div>
        `;
    }
    
    // Handle window resize and orientation change
    let resizeTimeout;
    window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
            if (turnInstance && originalWidth) {
                currentScale = calculateOptimalScale();
                fitToScreen();
            }
        }, 250);
    });
    
    // Orientation change detection for mobile
    window.addEventListener('orientationchange', function() {
        setTimeout(() => {
            if (turnInstance && originalWidth) {
                currentScale = calculateOptimalScale();
                fitToScreen();
            }
        }, 100);
    });
    
    // Event listeners
    document.getElementById('prev-page')?.addEventListener('click', goToPrevPage);
    document.getElementById('next-page')?.addEventListener('click', goToNextPage);
    document.getElementById('fullscreen-btn')?.addEventListener('click', toggleFullscreen);
    document.getElementById('download-btn')?.addEventListener('click', downloadPDF);
    document.getElementById('share-btn')?.addEventListener('click', copyShareLink);
    document.getElementById('zoom-in')?.addEventListener('click', zoomIn);
    document.getElementById('zoom-out')?.addEventListener('click', zoomOut);
    document.getElementById('zoom-reset')?.addEventListener('click', fitToScreen);
    
    // Keyboard navigation (desktop only)
    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') goToPrevPage();
        if (e.key === 'ArrowRight') goToNextPage();
        if (e.key === '+' || e.key === '=') zoomIn();
        if (e.key === '-' || e.key === '_') zoomOut();
        if (e.key === 'f' || e.key === 'F') toggleFullscreen();
        if (e.key === '0') fitToScreen();
    });
    
    // Start
    loadPDF();
</script>
</body>
</html>