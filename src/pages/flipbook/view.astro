<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Vobels Flipbook | Digital Publication</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="shortcut icon" href="/favicon.svg">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #2c2b28;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        
        .navbar {
            padding: 0.75rem 2rem;
            background: #1f1e1c;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
            z-index: 10;
        }
        
        .brand {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: 1.25rem;
            font-weight: 400;
            color: #e8e5df;
            text-decoration: none;
        }
        
        .toolbar {
            display: flex;
            gap: 0.5rem;
            align-items: center;
            flex-wrap: wrap;
        }
        
        .toolbar button {
            background: #3d3c38;
            border: none;
            padding: 0.5rem 1rem;
            font-size: 0.8rem;
            font-weight: 450;
            cursor: pointer;
            color: #e8e5df;
            transition: all 0.2s;
            border-radius: 4px;
        }
        
        .toolbar button:hover {
            background: #5a5852;
        }
        
        .page-info {
            font-size: 0.8rem;
            color: #a09d96;
            margin: 0 0.5rem;
        }
        
        .zoom-controls {
            display: flex;
            gap: 0.25rem;
            margin-left: 0.5rem;
            padding-left: 0.5rem;
        }
        
        .zoom-controls button {
            padding: 0.5rem 0.75rem;
            font-size: 0.8rem;
        }
        
        #flipbook-container {
            flex: 1;
            position: relative;
            overflow: auto;
            background: #2c2b28;

            display: flex;

            align-items: flex-start;

            justify-content: center;

            padding: 20px;
        }
        
        #flipbook {
            background: #e8e5df;
            position: relative;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            transform-origin: center center;
            transition: transform 0.2s ease;
        }
        
        /* Turn.js page styling */
        #flipbook .page {
            background: white;
            box-shadow: 0 0 15px rgba(0,0,0,0.2);
        }
        
        #flipbook .page img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
        }
        
        /* For proper display of double pages */
        #flipbook .double {
            background: white;
        }
        
        .loading-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #1f1e1c;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 1rem;
            z-index: 100;
        }
        
        .spinner {
            width: 40px;
            height: 40px;
            border: 2px solid #5a5852;
            border-top-color: #e8e5df;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }
        
        @keyframes spin { to { transform: rotate(360deg); } }
        
        .loading-overlay p {
            color: #a09d96;
        }
        
        .instruction {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.8);
            color: white;
            padding: 8px 20px;
            border-radius: 30px;
            font-size: 0.8rem;
            pointer-events: none;
            z-index: 20;
            opacity: 0;
            transition: opacity 0.5s;
            white-space: nowrap;
        }
        
        @media (max-width: 768px) {
            .navbar { padding: 0.5rem 1rem; }
            .toolbar button { padding: 0.4rem 0.75rem; font-size: 0.7rem; }
            .instruction { font-size: 0.7rem; bottom: 20px; white-space: nowrap; }
            #flipbook-container { padding: 10px; }
        }
        
        @media (max-width: 600px) {
            .navbar { flex-direction: column; align-items: stretch; }
            .toolbar { justify-content: center; }
            .instruction { font-size: 0.6rem; white-space: normal; text-align: center; width: 90%; }
        }
    </style>
</head>
<body>
    <div class="navbar">
        <a href="/" class="brand">Vobels Flipbook</a>
        <div class="toolbar">
            <button id="prev-page">← Previous</button>
            <span class="page-info">
                <span id="current-page">1</span> / <span id="total-pages">...</span>
            </span>
            <button id="next-page">Next →</button>
            <button id="fullscreen-btn">Fullscreen</button>
            <button id="download-btn">Download</button>
            <button id="share-btn">Share</button>
            <div class="zoom-controls">
                <button id="zoom-out" title="Zoom out">−</button>
                <button id="zoom-reset" title="Reset zoom">Fit</button>
                <button id="zoom-in" title="Zoom in">+</button>
            </div>
        </div>
    </div>
    
    <div id="flipbook-container">
        <div id="flipbook">
            <div class="loading-overlay">
                <div class="spinner"></div>
                <p>Loading publication...</p>
            </div>
        </div>
    </div>
    
    <div class="instruction" id="instruction">Click left or right edge of page to flip</div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/turn.js/3/turn.min.js"></script>
    
<script>
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
    
    let pdfDoc = null;
    let pageCount = 0;
    let currentPage = 1;
    let currentBookId = null;
    let pagesData = [];
    let originalWidth = 0;
    let originalHeight = 0;
    let currentScale = 1.0;
    let turnInstance = null;
    
    function getBookId() {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get('id');
    }
    
    async function loadPDF() {
        const bookId = getBookId();
        const urlParams = new URLSearchParams(window.location.search);
        const directPdfUrl = urlParams.get('pdf');
        
        // ========== DEBUG LOGGING ==========
        console.log("=== FLIPBOOK DEBUG INFO ===");
        console.log("Book ID from URL:", bookId);
        console.log("Direct PDF URL:", directPdfUrl);
        console.log("Full URL:", window.location.href);
        console.log("API URL:", `/api/flipbook?id=${bookId}`);
        // ===================================
        
        if (directPdfUrl) {
            console.log("Loading direct PDF from:", directPdfUrl);
            try {
                const loadingTask = pdfjsLib.getDocument(directPdfUrl);
                pdfDoc = await loadingTask.promise;
                pageCount = pdfDoc.numPages;
                document.getElementById('total-pages').textContent = pageCount;
                await getAndSetBookDimensions();
                await convertPagesToImages();
                return;
            } catch (error) {
                console.error("Direct PDF error:", error);
                showError(error);
                return;
            }
        }
        
        if (!bookId) {
            console.error("No book ID found in URL - check your link format");
            document.getElementById('flipbook').innerHTML = `
                <div class="loading-overlay">
                    <p>No publication specified</p>
                    <p style="font-size: 0.8rem; color: #a09d96; margin-top: 10px;">URL should contain ?id=BOOK_ID</p>
                    <p style="font-size: 0.7rem; color: #a09d96;">Example: /flipbook/view.?id=abc123</p>
                    <a href="/flipbook/create" style="color: #8b7e6b; margin-top: 1rem;">Create a flipbook →</a>
                </div>
            `;
            return;
        }
        
        currentBookId = bookId;
        
        try {
            console.log("Fetching from API...");
            const response = await fetch(`/api/flipbook?id=${bookId}`);
            console.log("API Response status:", response.status);
            
            const data = await response.json();
            console.log("API Response data:", JSON.stringify(data, null, 2));
            
            if (data.success && data.pdfUrl) {
                console.log("PDF URL received:", data.pdfUrl);
                console.log("Loading PDF from URL...");
                const loadingTask = pdfjsLib.getDocument(data.pdfUrl);
                pdfDoc = await loadingTask.promise;
                pageCount = pdfDoc.numPages;
                document.getElementById('total-pages').textContent = pageCount;
                await getAndSetBookDimensions();
                await convertPagesToImages();
                console.log("PDF loaded successfully!");
            } else {
                console.error("API returned error or no pdfUrl:", data.error);
                throw new Error(data.error || 'Unable to load flipbook - no PDF URL returned');
            }
        } catch (error) {
            console.error("Load error - full details:", error);
            showError(error);
        }
    }
    
    // Get actual PDF dimensions and calculate optimal display size
    async function getAndSetBookDimensions() {
        const firstPage = await pdfDoc.getPage(1);
        const viewport = firstPage.getViewport({ scale: 1 });
        
        originalWidth = viewport.width;
        originalHeight = viewport.height;
        
        // Calculate optimal display size (max 1000px width, 80% of viewport height)
        const container = document.getElementById('flipbook-container');
        const maxWidth = Math.min(1000, window.innerWidth - 100);
        const maxHeight = window.innerHeight - 150;
        
        // Calculate scale to fit within viewport
        const scaleByWidth = maxWidth / originalWidth;
        const scaleByHeight = maxHeight / originalHeight;
        const fitScale = Math.min(scaleByWidth, scaleByHeight, 1.2); // Cap at 120% max
        
        currentScale = fitScale;
        
        console.log(`Book dimensions: ${originalWidth}x${originalHeight}, Scale: ${currentScale}`);
    }
    
    async function convertPagesToImages() {
        const flipbookDiv = document.getElementById('flipbook');
        flipbookDiv.innerHTML = '<div class="loading-overlay"><div class="spinner"></div><p>Preparing pages...</p></div>';
        
        pagesData = [];
        
        // Use higher quality for better resolution
        const renderScale = 2.0;
        
        for (let i = 1; i <= pageCount; i++) {
            console.log(`Converting page ${i}/${pageCount}...`);
            const page = await pdfDoc.getPage(i);
            const viewport = page.getViewport({ scale: renderScale });
            const canvas = document.createElement('canvas');
            canvas.width = viewport.width;
            canvas.height = viewport.height;
            const context = canvas.getContext('2d');
            
            await page.render({ canvasContext: context, viewport }).promise;
            pagesData.push(canvas.toDataURL('image/jpeg', 0.92));
            
            // Update progress
            if (i % 5 === 0 || i === pageCount) {
                flipbookDiv.innerHTML = `<div class="loading-overlay"><div class="spinner"></div><p>Loading page ${i}/${pageCount}...</p></div>`;
            }
        }
        
        console.log(`All ${pageCount} pages converted successfully`);
        createFlipbook();
    }
    
    function createFlipbook() {
        const flipbookDiv = document.getElementById('flipbook');
        const container = document.getElementById('flipbook-container');
        
        // Build HTML with proper page divs
        let html = '';
        for (let i = 0; i < pagesData.length; i++) {
            html += `
                <div class="page" style="background: white;">
                    <img src="${pagesData[i]}" style="width: 100%; height: auto; display: block;" alt="Page ${i + 1}">
                </div>
            `;
        }
        flipbookDiv.innerHTML = html;
        
        // Set the flipbook size based on original dimensions and scale
        const viewportWidth = window.innerWidth - 80;
        const viewportHeight = window.innerHeight - 160;

        const scaleX = viewportWidth / originalWidth;
        const scaleY = viewportHeight / originalHeight;

        currentScale = 0.6;

        const displayWidth = originalWidth * currentScale;
        const displayHeight = originalHeight * currentScale;

        flipbookDiv.style.width = displayWidth + 'px';
        flipbookDiv.style.height = displayHeight + 'px';
        
        // Initialize turn.js
        $(flipbookDiv).turn({
            width: displayWidth,
            height: displayHeight,
            autoCenter: true,
            display: 'single',
            acceleration: true,
            gradients: false,
            elevation: 30,
            when: {
                turned: function(e, page) {
                    currentPage = page;
                    document.getElementById('current-page').textContent = currentPage;
                    updateButtons();
                },
                start: function(e, page, view) {
                    // Optional: Add page turn sound here
                }
            }
        });
        
        // Add click detection for page edges
        $(flipbookDiv).off('click').on('click', function(e) {
            const width = $(this).width();
            const clickX = e.clientX - $(this).offset().left;
            
            if (clickX < width * 0.25) {
                $(flipbookDiv).turn('previous');
                showInstruction('← Previous page', 800);
            } else if (clickX > width * 0.75) {
                $(flipbookDiv).turn('next');
                showInstruction('Next page →', 800);
            }
        });
        
        // Center the flipbook in container
        centerFlipbook();
        
        // Show instruction briefly
        showInstruction('Click left or right edges to flip pages', 2500);
        updateButtons();
        
        // Store turn instance reference
        turnInstance = flipbookDiv;
        
        // Check and add watermark for free users
        checkAndAddWatermark();
    }
    
    function centerFlipbook() {
        const flipbook = document.getElementById('flipbook');
        const container = document.getElementById('flipbook-container');
        
        if (flipbook && container) {
            const containerRect = container.getBoundingClientRect();
            const flipbookRect = flipbook.getBoundingClientRect();
            
            const scrollLeft = (flipbookRect.width - containerRect.width) / 2;
            const scrollTop = (flipbookRect.height - containerRect.height) / 2;
            
            container.scrollLeft = Math.max(0, scrollLeft);
            container.scrollTop = Math.max(0, scrollTop);
        }
    }
    
    function applyZoom() {
        if (!turnInstance) return;
        
        const displayWidth = originalWidth * currentScale;
        const displayHeight = originalHeight * currentScale;
        
        $(turnInstance).turn('size', displayWidth, displayHeight);
        $(turnInstance).turn('resize');
        
        turnInstance.style.width = displayWidth + 'px';
        turnInstance.style.height = displayHeight + 'px';
        
        // Update zoom button text
        document.getElementById('zoom-reset').textContent = Math.round(currentScale * 100) + '%';
        
        // Re-center after zoom
        centerFlipbook();
    }
    
    function zoomIn() {
        currentScale = Math.min(currentScale + 0.1, 2.0);
        applyZoom();
        showInstruction('Zoom: ' + Math.round(currentScale * 100) + '%', 500);
    }
    
    function zoomOut() {
        currentScale = Math.max(currentScale - 0.1, 0.5);
        applyZoom();
        showInstruction('Zoom: ' + Math.round(currentScale * 100) + '%', 500);
    }
    
    function fitToScreen() {

        currentScale = 0.6;

        applyZoom();

        showInstruction('Fit: 60%', 500);
    }
    
    function updateButtons() {
        const prevBtn = document.getElementById('prev-page');
        const nextBtn = document.getElementById('next-page');
        if (prevBtn) prevBtn.disabled = currentPage <= 1;
        if (nextBtn) nextBtn.disabled = currentPage >= pageCount;
    }
    
    function goToPrevPage() { 
        if (currentPage > 1 && turnInstance) {
            $(turnInstance).turn('previous');
            showInstruction('← Previous page', 500);
        }
    }
    
    function goToNextPage() { 
        if (currentPage < pageCount && turnInstance) {
            $(turnInstance).turn('next');
            showInstruction('Next page →', 500);
        }
    }
    
    function toggleFullscreen() { 
        const container = document.getElementById('flipbook-container');
        if (!document.fullscreenElement) {
            container.requestFullscreen().then(() => {
                setTimeout(() => centerFlipbook(), 100);
            });
        } else {
            document.exitFullscreen();
        }
    }
    
    function downloadPDF() { 
        if (currentBookId) {
            window.location.href = `/api/flipbook?id=${currentBookId}&download=true`;
        } else {
            alert('Download not available for this PDF');
        }
    }
    
    function copyShareLink() {
        navigator.clipboard.writeText(window.location.href);
        showInstruction('✓ Link copied to clipboard!', 1500);
    }
    
    function showInstruction(message, duration) {
        const inst = document.getElementById('instruction');
        inst.textContent = message;
        inst.style.opacity = '1';
        setTimeout(() => {
            inst.style.opacity = '0';
        }, duration);
    }
    
    // WATERMARK FUNCTION - Shows watermark for free users only
    async function checkAndAddWatermark() {
        const bookId = getBookId();
        if (!bookId) return;
    
        try {
            console.log("Checking watermark status for book:", bookId);
            const response = await fetch(`/api/check-flipbook-plan?id=${bookId}`);
            const data = await response.json();
            console.log("Watermark check response:", data);
    
            // If not premium, add watermark
            if (!data.isPremium) {
                console.log("Free user - adding watermark");
                const watermark = document.createElement('div');
                watermark.id = 'vobels-watermark';
                watermark.innerHTML = `
                    <div style="
                        position: fixed;
                        bottom: 20px;
                        right: 20px;
                        z-index: 9999;
                        opacity: 0.35;
                        font-family: 'Playfair Display', serif;
                        font-size: 11px;
                        color: #888;
                        background: rgba(0,0,0,0.03);
                        padding: 4px 12px;
                        border-radius: 20px;
                        pointer-events: none;
                    ">
                        Created with Vobels Flipbook
                    </div>
                `;
                document.body.appendChild(watermark);
            } else {
                console.log("Premium user - no watermark");
            }
        } catch (err) {
            console.error('Watermark check failed:', err);
            // Add watermark anyway on error (fail safe - free users get watermark)
            const watermark = document.createElement('div');
            watermark.id = 'vobels-watermark';
            watermark.innerHTML = `<div style="position:fixed;bottom:20px;right:20px;z-index:9999;opacity:0.3;font-size:11px;background:rgba(0,0,0,0.03);padding:4px12px;border-radius:20px;">Vobels Flipbook</div>`;
            document.body.appendChild(watermark);
        }
    }
    
    function showError(error) {
        console.error("SHOWING ERROR:", error.message);
        document.getElementById('flipbook').innerHTML = `
            <div class="loading-overlay">
                <p style="color: #e8e5df;">Unable to load this publication</p>
                <p style="font-size: 0.8rem; color: #a09d96; margin-top: 10px;">Error: ${error.message}</p>
                <p style="font-size: 0.7rem; color: #a09d96; margin-top: 10px;">Book ID: ${currentBookId || 'none'}</p>
                <p style="font-size: 0.7rem; color: #a09d96;">Check browser console (F12) for details</p>
                <a href="/flipbook/upload.html" style="color: #e8e5df; margin-top: 1rem;">Create new flipbook →</a>
            </div>
        `;
    }
    
    // Handle window resize
    let resizeTimeout;
    window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
            if (turnInstance) {
                fitToScreen();
            }
            centerFlipbook();
        }, 250);
    });
    
    // Event listeners
    document.getElementById('prev-page')?.addEventListener('click', goToPrevPage);
    document.getElementById('next-page')?.addEventListener('click', goToNextPage);
    document.getElementById('fullscreen-btn')?.addEventListener('click', toggleFullscreen);
    document.getElementById('download-btn')?.addEventListener('click', downloadPDF);
    document.getElementById('share-btn')?.addEventListener('click', copyShareLink);
    document.getElementById('zoom-in')?.addEventListener('click', zoomIn);
    document.getElementById('zoom-out')?.addEventListener('click', zoomOut);
    document.getElementById('zoom-reset')?.addEventListener('click', fitToScreen);
    
    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') goToPrevPage();
        if (e.key === 'ArrowRight') goToNextPage();
        if (e.key === '+' || e.key === '=') zoomIn();
        if (e.key === '-' || e.key === '_') zoomOut();
        if (e.key === 'f' || e.key === 'F') toggleFullscreen();
        if (e.key === '0') fitToScreen();
    });
    
    // Start
    console.log("Viewer initialized - starting loadPDF()");
    loadPDF();
</script>
</body>
</html>