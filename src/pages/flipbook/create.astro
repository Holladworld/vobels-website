---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Create Flipbook | Vobels" description="Upload your PDF and create a stunning flipbook">
  <Container>
    <div class="mt-10 max-w-3xl mx-auto">
      <!-- Header with Navigation -->
      <div class="text-center mb-8">
        <div class="flex justify-between items-center mb-4">
          <a href="/flipbook" class="text-zinc-500 hover:text-black text-sm">← Back</a>
          <a href="/flipbook/my-books" class="text-zinc-500 hover:text-black text-sm"> My Books →</a>
        </div>
        <h1 class="text-3xl md:text-3xl font-bold text-black">Create a Flipbook</h1>
        <p class="text-zinc-500 mt-2">Transform your PDF into an elegant, shareable digital publication</p>
      </div>

      <!-- Email Section -->
      <div class="bg-white border border-zinc-200 rounded-xl p-6 mb-6">
        <label class="block text-sm font-medium text-black mb-2">Your Email *</label>
        <input
          type="email"
          id="userEmail"
          class="w-full px-4 py-2 border border-zinc-300 rounded-lg focus:ring-2 focus:ring-black outline-none"
          placeholder="you@example.com"
        />
        <div id="limitInfo" class="text-sm mt-2"></div>
      </div>

      <!-- Upload Area -->
      <div class="bg-white border-2 border-dashed border-zinc-300 rounded-xl p-8 text-center hover:border-black transition-all cursor-pointer" id="dropzone">
        <Icon name="bx:upload" class="w-12 h-12 text-zinc-400 mx-auto mb-4" />
        <p class="text-black font-medium">Click or drag your PDF here</p>
        <p class="text-xs text-zinc-400 mt-1">Maximum file size: 50MB</p>
        <input type="file" id="fileInput" accept=".pdf" class="hidden" />
      </div>

      <div id="fileSelected" class="hidden mt-4 text-center text-green-600 text-sm"></div>

      <button id="uploadBtn" class="w-full bg-black text-white py-3 rounded-lg font-medium hover:bg-zinc-800 transition-all mt-6 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
        Create Flipbook →
      </button>

      <!-- Result Section -->
      <div id="resultSection" class="hidden mt-8 bg-green-50 border border-green-200 rounded-xl p-6 text-center">
        <Icon name="bx:check-circle" class="w-12 h-12 text-green-600 mx-auto mb-3" />
        <h3 class="font-bold text-black mb-2">Your flipbook is ready!</h3>
        <div class="flex gap-2 mt-4 flex-wrap">
          <input type="text" id="shareUrl" class="flex-1 px-3 py-2 border border-zinc-300 rounded-lg text-sm" readonly />
          <button id="copyBtn" class="bg-black text-white px-4 py-2 rounded-lg text-sm hover:bg-zinc-800">Copy</button>
          <a id="viewLink" href="#" target="_blank" class="bg-zinc-100 text-black border-2 border-black px-4 py-2 rounded-lg text-sm hover:bg-zinc-200">View Book</a>
        </div>
        <div class="mt-4">
          <a href="/flipbook/create" class="text-green-700 text-sm hover:underline">+ Create another flipbook</a>
        </div>
      </div>

      <!-- Loading -->
      <div id="loadingIndicator" class="hidden text-center py-8">
        <div class="inline-block w-8 h-8 border-2 border-zinc-300 border-t-black rounded-full animate-spin"></div>
        <p class="text-zinc-500 mt-2">Processing your document...</p>
      </div>

      <!-- Info Note -->
      <div class="mt-8 bg-zinc-50 rounded-lg p-4 text-center text-s text-zinc-500">
        <p>Free: 3 flipbooks • 3-day expiry • Watermarked</p>
        <p class="mt-1">Premium: Unlimited • No watermark • Permanent storage</p>
        <a href="/flipbook/pricing" class="text-black font-medium underline mt-2 inline-block">Upgrade to Premium →</a>
      </div>
    </div>
  </Container>

  <!-- Toast Notification -->
  <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden">
    <div class="flex items-center gap-3 px-5 py-3 rounded-xl shadow-lg bg-white border">
      <span id="toast-icon"></span>
      <span id="toast-message" class="text-sm font-medium"></span>
    </div>
  </div>

  <style is:inline>
    @keyframes spin { to { transform: rotate(360deg); } }
    .animate-spin { animation: spin 1s linear infinite; }
  </style>

  <script>
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      const toastIcon = document.getElementById('toast-icon');
      const toastMessage = document.getElementById('toast-message');
      const toastDiv = toast.querySelector('div');

      toastDiv.classList.remove('border-green-200', 'bg-green-50', 'border-red-200', 'bg-red-50', 'border-amber-200', 'bg-amber-50');
      toastMessage.classList.remove('text-green-800', 'text-red-800', 'text-amber-800');

      if (type === 'success') {
        toastIcon.innerHTML = '<svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
        toastDiv.classList.add('border-green-200', 'bg-green-50');
        toastMessage.classList.add('text-green-800');
      } else if (type === 'error') {
        toastIcon.innerHTML = '<svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>';
        toastDiv.classList.add('border-red-200', 'bg-red-50');
        toastMessage.classList.add('text-red-800');
      } else {
        toastIcon.innerHTML = '<svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>';
        toastDiv.classList.add('border-amber-200', 'bg-amber-50');
        toastMessage.classList.add('text-amber-800');
      }

      toastMessage.textContent = message;
      toast.classList.remove('hidden');

      setTimeout(() => {
        toast.classList.add('hidden');
      }, 3000);
    }

    document.addEventListener('DOMContentLoaded', function() {
      const emailInput = document.getElementById('userEmail');
      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const uploadBtn = document.getElementById('uploadBtn');
      const loadingIndicator = document.getElementById('loadingIndicator');
      const resultSection = document.getElementById('resultSection');
      const shareUrlInput = document.getElementById('shareUrl');
      const copyBtn = document.getElementById('copyBtn');
      const viewLink = document.getElementById('viewLink');
      const fileSelected = document.getElementById('fileSelected');
      const limitInfo = document.getElementById('limitInfo');

      let selectedFile = null;
      let isPremium = false;
      let isAdmin = false;
      let remainingUploads = 3;

      const savedEmail = localStorage.getItem('flipbook_user_email');
      if (savedEmail && emailInput) {
        emailInput.value = savedEmail;
      }

      let emailTimeout;
      if (emailInput) {
        emailInput.addEventListener('input', function() {
          clearTimeout(emailTimeout);
          emailTimeout = setTimeout(checkUserStatus, 500);
          localStorage.setItem('flipbook_user_email', emailInput.value);
        });
      }

      async function checkUserStatus() {
        const email = emailInput?.value.trim();

        const adminEmails = ['vobels.co@gmail.com', 'admin@vobels.com.ng'];
        const isLocalAdmin = adminEmails.includes(email);

        if (!email || !email.includes('@')) {
          if (limitInfo) limitInfo.innerHTML = '<span class="text-zinc-500">Enter email to check status</span>';
          return;
        }

        if (limitInfo) limitInfo.innerHTML = '<span class="text-zinc-500">Checking status...</span>';

        try {
          const res = await fetch('/api/check-user', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email })
          });

          const data = await res.json();
          console.log('User status:', data);

          isPremium = data.isPremium || false;
          isAdmin = isLocalAdmin || data.isAdmin || false;
          remainingUploads = data.remainingUploads !== undefined ? data.remainingUploads : 3;

          if (limitInfo) {
            if (isAdmin) {
              limitInfo.innerHTML = '<span class="text-purple-600 font-medium">👑 Admin account - Unlimited uploads, no watermark, permanent storage</span>';
            } else if (isPremium) {
              limitInfo.innerHTML = '<span class="text-green-600 font-medium">✨ Premium account - Unlimited uploads, no watermark, permanent storage</span>';
            } else {
              limitInfo.innerHTML = `<span class="text-amber-600">📄 Free plan: ${remainingUploads} uploads remaining (3-day expiry, watermark)</span>`;
            }
          }
        } catch (err) {
          console.error('Status check error:', err);
          if (limitInfo) limitInfo.innerHTML = '<span class="text-red-500">Unable to check status</span>';
          isPremium = false;
          isAdmin = false;
          remainingUploads = 3;
        }
      }

      if (dropzone) {
        dropzone.addEventListener('click', () => fileInput?.click());

        dropzone.addEventListener('dragover', (e) => {
          e.preventDefault();
          dropzone.classList.add('border-black');
        });

        dropzone.addEventListener('dragleave', () => {
          dropzone.classList.remove('border-black');
        });

        dropzone.addEventListener('drop', (e) => {
          e.preventDefault();
          dropzone.classList.remove('border-black');
          const files = e.dataTransfer.files;
          if (files[0] && files[0].type === 'application/pdf') {
            handleFile(files[0]);
          } else {
            showToast('Please select a valid PDF file', 'error');
          }
        });
      }

      if (fileInput) {
        fileInput.addEventListener('change', (e) => {
          if (e.target.files?.[0]) {
            handleFile(e.target.files[0]);
          }
        });
      }

      function handleFile(file) {
        if (file.size > 50 * 1024 * 1024) {
          showToast('File too large. Maximum size is 50MB.', 'error');
          return;
        }

        selectedFile = file;
        if (fileSelected) {
          fileSelected.classList.remove('hidden');
          fileSelected.innerHTML = `✓ ${file.name} (${(file.size / 1024 / 1024).toFixed(2)} MB)`;
        }
        if (uploadBtn) uploadBtn.disabled = false;
      }

      if (uploadBtn) {
        uploadBtn.addEventListener('click', async function() {
          const email = emailInput?.value.trim();
          const adminEmails = ['vobels.co@gmail.com', 'admin@vobels.com.ng'];
          const isLocalAdmin = adminEmails.includes(email);

          if (!email || !email.includes('@')) {
            showToast('Please enter a valid email address', 'warning');
            emailInput?.focus();
            return;
          }

          if (!selectedFile) {
            showToast('Please select a PDF file', 'warning');
            return;
          }

          if (!isLocalAdmin && !isPremium && remainingUploads <= 0) {
            showToast('Free limit reached (3 flipbooks). Upgrade to premium for unlimited uploads.', 'warning');
            setTimeout(() => {
              window.location.href = '/flipbook/pricing';
            }, 2000);
            return;
          }

          const formData = new FormData();
          formData.append('pdf', selectedFile);
          formData.append('email', email);

          uploadBtn.disabled = true;
          if (loadingIndicator) loadingIndicator.classList.remove('hidden');

          try {
            const res = await fetch('/api/flipbook', { method: 'POST', body: formData });
            const data = await res.json();
            console.log('Upload response:', data);

            if (data.success) {
              const fullUrl = data.shareUrl.startsWith('http') ? data.shareUrl : window.location.origin + data.shareUrl;
              if (shareUrlInput) shareUrlInput.value = fullUrl;
              if (viewLink) viewLink.href = fullUrl;
              if (resultSection) resultSection.classList.remove('hidden');
              showToast('Flipbook created successfully!', 'success');
              selectedFile = null;
              if (fileSelected) fileSelected.classList.add('hidden');
              if (fileInput) fileInput.value = '';
              uploadBtn.disabled = true;
              checkUserStatus();
            } 
            else if (data.error === "DUPLICATE_FILE") {
              showToast(data.message || 'This file already exists! Check your "My Books" page.', 'warning');
              // Reset the form
              selectedFile = null;
              if (fileSelected) fileSelected.classList.add('hidden');
              if (fileInput) fileInput.value = '';
            }
            else if (data.limitReached) {
              showToast('Free limit reached. Upgrade to premium for unlimited uploads.', 'warning');
              setTimeout(() => {
                window.location.href = '/flipbook/pricing';
              }, 2000);
            } 
            else {
              showToast(data.error || 'Upload failed', 'error');
            }
          } catch (err) {
            console.error('Upload error:', err);
            showToast('Something went wrong. Please try again.', 'error');
          } finally {
            if (loadingIndicator) loadingIndicator.classList.add('hidden');
            uploadBtn.disabled = false;
          }
        });
      }

      copyBtn?.addEventListener('click', function() {
        if (shareUrlInput) {
          navigator.clipboard.writeText(shareUrlInput.value);
          showToast('Link copied to clipboard!', 'success');
        }
      });

      if (savedEmail) {
        checkUserStatus();
      }
    });
  </script>
</Layout>