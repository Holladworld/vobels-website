---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
---

<Layout title="Flipbook Pricing | Vobels" description="Upgrade to Premium for unlimited flipbooks">
  <Container>
    <!-- Header -->
    <div class="mt-16 text-center max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-black tracking-tighter">Upgrade to Premium</h1>
      <p class="text-xl text-zinc-600 mt-4">Get unlimited flipbooks, remove watermark, and enjoy permanent storage</p>
    </div>

    <!-- Email Check -->
    <div class="max-w-md mx-auto mt-8">
      <input 
        type="email" 
        id="userEmail" 
        class="w-full px-4 py-3 border border-zinc-300 rounded-lg focus:ring-2 focus:ring-black outline-none text-center"
        placeholder="Enter your email to check status"
      />
      <div id="statusDisplay" class="text-center text-sm mt-2"></div>
    </div>

    <!-- Pricing Cards -->
    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto mt-12">
      
      <!-- Free Plan -->
      <div class="bg-white border border-zinc-200 rounded-xl p-6 text-center hover:shadow-lg transition-all">
        <h3 class="font-bold text-xl mb-2">Free</h3>
        <p class="text-3xl font-black mb-4">₦0<span class="text-sm font-normal">/month</span></p>
        <ul class="space-y-2 text-sm mb-6">
          <li class="flex items-center justify-center gap-2">✓ 3 flipbooks</li>
          <li class="flex items-center justify-center gap-2">✓ 3-day storage</li>
          <li class="flex items-center justify-center gap-2 text-zinc-400">✗ Watermark</li>
        </ul>
        <a href="/flipbook/create" class="block bg-zinc-100 text-black py-2 rounded-lg font-medium hover:bg-zinc-200 transition-all">Get Started</a>
      </div>

      <!-- Premium Monthly -->
      <div class="bg-white border-2 border-black rounded-xl p-6 text-center relative hover:shadow-lg transition-all">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-black text-white text-xs px-3 py-1 rounded-full font-medium">Most Popular</div>
        <h3 class="font-bold text-xl mb-2">Premium Monthly</h3>
        <p class="text-3xl font-black mb-4">₦3,000<span class="text-sm font-normal">/month</span></p>
        <ul class="space-y-2 text-sm mb-6">
          <li class="flex items-center justify-center gap-2">✓ Unlimited flipbooks</li>
          <li class="flex items-center justify-center gap-2">✓ Permanent storage</li>
          <li class="flex items-center justify-center gap-2">✓ No watermark</li>
        </ul>
        <button id="payMonthlyBtn" class="w-full bg-black text-white py-2 rounded-lg font-medium hover:bg-zinc-800 transition-all cursor-pointer">Upgrade Now →</button>
      </div>

      <!-- Business -->
      <div class="bg-white border border-zinc-200 rounded-xl p-6 text-center hover:shadow-lg transition-all">
        <h3 class="font-bold text-xl mb-2">Business</h3>
        <p class="text-3xl font-black mb-4">Custom</p>
        <ul class="space-y-2 text-sm mb-6">
          <li class="flex items-center justify-center gap-2">✓ Everything in Premium</li>
          <li class="flex items-center justify-center gap-2">✓ Custom branding</li>
          <li class="flex items-center justify-center gap-2">✓ Team accounts</li>
        </ul>
        <a href="/contact" class="block bg-zinc-100 text-black py-2 rounded-lg font-medium hover:bg-zinc-200 transition-all">Contact Sales →</a>
      </div>
    </div>

    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
      <div class="bg-white rounded-xl p-6 text-center">
        <div class="inline-block w-8 h-8 border-2 border-zinc-300 border-t-black rounded-full animate-spin"></div>
        <p class="mt-3 text-zinc-600">Processing your payment...</p>
      </div>
    </div>

    <div class="text-center mt-12 text-sm text-zinc-500">
      <p>Secure payments powered by Paystack</p>
    </div>
  </Container>

  <!-- Load Paystack script dynamically -->
  <script>
    // First, load Paystack script
    const script = document.createElement('script');
    script.src = 'https://js.paystack.co/v1/inline.js';
    script.onload = function() {
      console.log('Paystack loaded successfully');
      window.paystackLoaded = true;
    };
    script.onerror = function() {
      console.error('Failed to load Paystack');
      window.paystackLoaded = false;
    };
    document.head.appendChild(script);
  </script>

  <script>
    // Wait for DOM and Paystack to be ready
    function initPricing() {
      console.log('Initializing pricing page');
      
      const PAYSTACK_KEY = 'pk_live_135bc22afe817f240cf8027b58af14428fda30dd';
      let currentEmail = '';
      
      const emailInput = document.getElementById('userEmail');
      const payBtn = document.getElementById('payMonthlyBtn');
      const statusDiv = document.getElementById('statusDisplay');
      const loadingOverlay = document.getElementById('loadingOverlay');
      
      if (!payBtn) {
        console.error('Button not found!');
        return;
      }
      
      console.log('Button found');
      
      // Load saved email
      const savedEmail = localStorage.getItem('flipbook_user_email');
      if (savedEmail && emailInput) {
        emailInput.value = savedEmail;
        currentEmail = savedEmail;
        statusDiv.innerHTML = '<span class="text-green-600">✓ Email ready</span>';
      }
      
      // Update email as user types
      if (emailInput) {
        emailInput.addEventListener('input', function(e) {
          currentEmail = e.target.value.trim();
          localStorage.setItem('flipbook_user_email', currentEmail);
          if (currentEmail && currentEmail.includes('@')) {
            statusDiv.innerHTML = '<span class="text-green-600">✓ Email ready</span>';
          } else {
            statusDiv.innerHTML = '';
          }
        });
      }
      
      // Payment function
      function startPayment() {
        console.log('startPayment called, email:', currentEmail);
        
        if (!currentEmail || !currentEmail.includes('@')) {
          alert('Please enter a valid email address');
          emailInput.focus();
          return;
        }
        
        // Check if Paystack is loaded
        if (typeof PaystackPop === 'undefined') {
          console.log('Paystack not loaded yet, waiting...');
          alert('Loading payment system. Please click again in a moment.');
          return;
        }
        
        const reference = 'FLIP_' + Date.now() + '_' + Math.random().toString(36).substr(2, 8);
        console.log('Starting payment with reference:', reference);
        
        const handler = PaystackPop.setup({
          key: PAYSTACK_KEY,
          email: currentEmail,
          amount: 3000 * 100,
          currency: 'NGN',
          ref: reference,
          metadata: {
            custom_fields: [
              { display_name: "Product", variable_name: "product_name", value: "Flipbook Premium - Monthly" },
              { display_name: "Category", variable_name: "category", value: "flipbook_premium" },
              { display_name: "Product ID", variable_name: "product_id", value: "FLIPBOOK_PRO_MONTHLY" }
            ]
          },
          callback: function(response) {
            console.log('Payment success:', response);
            loadingOverlay.style.display = 'flex';
            
            fetch('/api/upgrade-flipbook', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                reference: response.reference,
                email: currentEmail,
                plan: 'monthly'
              })
            })
            .then(res => res.json())
            .then(data => {
              loadingOverlay.style.display = 'none';
              if (data.success) {
                alert('Payment successful! Your account has been upgraded to Premium.');
                window.location.href = '/flipbook/create';
              } else {
                alert('Payment successful but verification failed. Please contact support.');
              }
            })
            .catch(err => {
              loadingOverlay.style.display = 'none';
              console.error('Upgrade error:', err);
              alert('Something went wrong. Please contact support.');
            });
          },
          onClose: function() {
            console.log('Payment window closed');
            loadingOverlay.style.display = 'none';
          }
        });
        
        handler.openIframe();
        loadingOverlay.style.display = 'flex';
      }
      
      // Attach click event
      payBtn.onclick = function(e) {
        e.preventDefault();
        console.log('Button clicked!');
        startPayment();
      };
      
      console.log('Event handler attached');
    }
    
    // Run when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPricing);
    } else {
      initPricing();
    }
  </script>
</Layout>