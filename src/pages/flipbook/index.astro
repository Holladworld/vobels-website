---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Vobels Flipbook - Create Stunning Digital Publications" description="Transform your PDFs into elegant, shareable flipbooks. Free plan available.">
  <Container>
    <!-- Hero Section -->
    <div class="mt-16 text-center max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-black tracking-tighter">
        Transform PDFs into Elegant Digital Flipbooks
      </h1>
      <p class="text-xl text-zinc-600 mt-4">
        Create stunning, shareable publications that feel like a luxury magazine.
      </p>
      <div class="mt-8">
        <a href="/flipbook/create" class="inline-block bg-black text-white px-8 py-3 rounded-lg font-medium hover:bg-zinc-800 transition-all">
          Create Your First Flipbook →
        </a>
      </div>
    </div>

    <!-- How it works -->
    <div class="grid md:grid-cols-3 gap-8 mt-20">
      <div class="text-center">
        <div class="w-16 h-16 bg-black rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            <path d="M9 7h6M9 11h6M9 15h4"/>
          </svg>
        </div>
        <h3 class="font-bold text-black mb-2">1. Upload PDF</h3>
        <p class="text-zinc-500 text-sm">Your document</p>
      </div>
      
      <div class="text-center">
        <div class="w-16 h-16 bg-black rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M8 8h8M8 12h6M8 16h4"/>
          </svg>
        </div>
        <h3 class="font-bold text-black mb-2">2. Becomes Flipbook</h3>
        <p class="text-zinc-500 text-sm">Interactive pages</p>
      </div>
      
      <div class="text-center">
        <div class="w-16 h-16 bg-black rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 12h8M12 8v8"/>
          </svg>
        </div>
        <h3 class="font-bold text-black mb-2">3. Share Anywhere</h3>
        <p class="text-zinc-500 text-sm">Unique link</p>
      </div>
    </div>

    <!-- Features -->
    <div class="mt-20">
      <h2 class="text-2xl font-bold text-center mb-8">Why Choose Vobels Flipbook</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: "Simple Upload", desc: "Upload any PDF and get a shareable link in seconds" },
          { title: "Interactive Flipping", desc: "Realistic page-flipping experience" },
          { title: "Easy Sharing", desc: "Share on social media or embed on your website" },
          { title: "Mobile Responsive", desc: "Perfect on any device" },
          { title: "Fullscreen Mode", desc: "Immersive reading experience" },
          { title: "Premium Upgrades", desc: "Remove watermark, unlimited uploads" }
        ].map((feature) => (
          <div class="bg-white border border-zinc-200 rounded-xl p-6 hover:shadow-lg transition-all">
            <Icon name="bx:check-circle" class="w-8 h-8 text-green-600 mb-3" />
            <h3 class="font-bold text-black mb-2">{feature.title}</h3>
            <p class="text-zinc-500 text-sm">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Pricing -->
    <div class="mt-20">
      <h2 class="text-2xl font-bold text-center mb-8">Simple, Transparent Pricing</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white border border-zinc-200 rounded-xl p-6 text-center">
          <h3 class="font-bold text-xl mb-2">Free</h3>
          <p class="text-3xl font-black mb-4">₦0<span class="text-sm font-normal">/month</span></p>
          <ul class="space-y-2 text-sm mb-6">
            <li>✓ 3 flipbooks</li>
            <li>✓ 3-day storage</li>
            <li>✗ Watermark</li>
          </ul>
          <a href="/flipbook/create" class="block bg-zinc-100 text-black py-2 rounded-lg">Get Started</a>
        </div>
        
        <div class="bg-white border-2 border-black rounded-xl p-6 text-center relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-black text-white text-xs px-3 py-1 rounded-full">Popular</div>
          <h3 class="font-bold text-xl mb-2">Premium</h3>
          <p class="text-3xl font-black mb-4">₦3,000<span class="text-sm font-normal">/month</span></p>
          <ul class="space-y-2 text-sm mb-6">
            <li>✓ Unlimited flipbooks</li>
            <li>✓ Permanent storage</li>
            <li>✓ No watermark</li>
          </ul>
          <a href="/flipbook/pricing" class="block bg-black text-white py-2 rounded-lg">Upgrade Now</a>
        </div>
        
        <div class="bg-white border border-zinc-200 rounded-xl p-6 text-center">
          <h3 class="font-bold text-xl mb-2">Business</h3>
          <p class="text-3xl font-black mb-4">Custom</p>
          <ul class="space-y-2 text-sm mb-6">
            <li>✓ Everything in Premium</li>
            <li>✓ Custom branding</li>
            <li>✓ Team accounts</li>
          </ul>
          <a href="/contact" class="block bg-zinc-100 text-black py-2 rounded-lg">Contact Sales</a>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-20 mb-20 bg-black rounded-2xl p-12 text-center text-white">
      <h2 class="text-2xl font-bold mb-4">Ready to Create Your First Flipbook?</h2>
      <p class="mb-8">Join hundreds of businesses using Vobels Flipbook.</p>
      <a href="/flipbook/create" class="inline-block bg-white text-black px-8 py-3 rounded-lg font-medium hover:bg-zinc-100 transition-all">
        Start Creating Free →
      </a>
    </div>
  </Container>
</Layout>