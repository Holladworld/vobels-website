---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
---

<Layout title="Secure Checkout | Vobels Academy">
  <Container>
    <div class="mt-20 max-w-md mx-auto mb-20">
      <div class="bg-white p-8 rounded-[2.5rem] border border-zinc-200 shadow-2xl">
        <div class="text-center mb-8">
          <h1 class="text-2xl font-bold text-black">Complete Enrollment</h1>
          <p class="text-zinc-500 text-sm mt-2">Certified Registration Agent Program</p>
        </div>

        <form id="paymentForm" class="space-y-6">
          <div class="bg-zinc-50 p-6 rounded-2xl space-y-3 border border-zinc-100">
            <div class="flex justify-between text-sm">
              <span class="text-zinc-500">Standard Fee</span>
              <span class="text-black font-medium">₦20,000</span>
            </div>
            
            <div id="discount-row" class="flex justify-between text-sm">
              <span class="text-green-600 font-medium">20% Early Bird Discount</span>
              <span class="text-green-600 font-medium">-₦4,000</span>
            </div>

            <div class="pt-3 border-t border-zinc-200 flex justify-between items-center">
              <span class="font-bold text-black">Total Amount</span>
              <span id="display-price" class="text-2xl font-black text-black">₦16,000</span>
            </div>
            
            <div id="countdown" class="text-[10px] text-center font-bold text-red-600 uppercase tracking-widest mt-2"></div>
          </div>

          <div class="space-y-4">
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">Full Name</label>
              <input type="text" id="full-name" required class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:ring-2 focus:ring-black outline-none transition-all" placeholder="John Doe" />
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">Email</label>
                <input type="email" id="email-address" required class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:ring-2 focus:ring-black outline-none transition-all" placeholder="you@email.com" />
              </div>
              <div>
                <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">WhatsApp No.</label>
                <input type="tel" id="phone-number" required class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:ring-2 focus:ring-black outline-none transition-all" placeholder="+23380123..." />
              </div>
            </div>
          </div>
          
          <button type="submit" class="w-full bg-black text-white font-bold py-4 rounded-2xl hover:bg-zinc-800 transition-all flex items-center justify-center gap-2">
            <span>Secure My Spot</span>
          </button>
        </form>
      </div>
    </div>
  </Container>

 <script is:inline src="https://js.paystack.co/v1/inline.js"></script>
  <script is:inline>
    const GLOBAL_KEY = 'vobels_global_deadline';
    let currentPrice = 16000; // Default discounted price

    function updateCheckoutState() {
      const deadline = localStorage.getItem(GLOBAL_KEY);
      const now = Date.now();
      const remaining = deadline - now;
      
      const discountRow = document.getElementById('discount-row');
      const displayPrice = document.getElementById('display-price');
      const countdownEl = document.getElementById('countdown');

      if (remaining <= 0) {
        currentPrice = 20000;
        if(discountRow) discountRow.style.display = 'none';
        displayPrice.innerText = "₦20,000";
        countdownEl.innerText = "OFFER EXPIRED";
      } else {
        currentPrice = 16000;
        const h = Math.floor(remaining / (1000 * 60 * 60));
        const m = Math.floor((remaining % (1000 * 60 * 60)) / (1000 * 60));
        const s = Math.floor((remaining % (1000 * 60)) / 1000);
        countdownEl.innerText = `Discount Price Expires in: ${h}h ${m}m ${s}s`;
      }
    }

    // Run price check immediately and every second
    setInterval(updateCheckoutState, 1000);
    updateCheckoutState();

    // Paystack Handler
    document.getElementById('paymentForm').addEventListener("submit", function(e) {
      e.preventDefault();
      
      const email = document.getElementById("email-address").value;
      const name = document.getElementById("full-name").value;
      const phone = document.getElementById("phone-number").value;

      let handler = PaystackPop.setup({
        key: 'pk_live_135bc22afe817f240cf8027b58af14428fda30dd',
        email: email,
        amount: currentPrice * 100,
        currency: "NGN",
        ref: 'VBL-' + Math.floor((Math.random() * 1000000000) + 1),
        metadata: {
          // ✅ ADDED CATEGORY FIELD
          category: "agent",
          product_name: "Certified Registration Agent Program",
          product_id: "AGENT_PRO_001",
          whatsapp_no: phone,
          custom_fields: [
            { display_name: "Full Name", variable_name: "full_name", value: name },
            { display_name: "Phone Number", variable_name: "phone_number", value: phone }
          ]
        },
        callback: function(response){
          window.location.href = "/academy/payment-success?ref=" + response.reference;
        }
      });
      handler.openIframe();
    });
  </script>
</Layout>