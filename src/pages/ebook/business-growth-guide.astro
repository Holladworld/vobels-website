---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

const fileId = "11fQ5pJ7k5JrQmeuF7WpZ82Ar9RvxzgzC";
const pdfPreviewLink = `https://drive.google.com/file/d/${fileId}/preview`;
const pdfDownloadLink = `https://drive.google.com/uc?export=download&id=${fileId}`;
---

<Layout title="Free Business Growth E-book | Vobels Limited">
  <Container>
    <div class="mt-16 max-w-5xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-10">
        <h1 class="text-3xl md:text-4xl font-bold text-black">From Small Business to Enterprise</h1>
        <p class="text-xl text-zinc-600 mt-3">A Practical Growth Guide for Nigerian Entrepreneurs</p>
        <div class="w-20 h-1 bg-black mx-auto mt-4"></div>
      </div>

      <!-- Flipbook Embed -->
      <div class="bg-white rounded-2xl shadow-xl overflow-hidden mb-8">
        <div class="bg-black text-white p-4 text-center">
          <h2 class="font-semibold">Read Online (Flipbook Style)</h2>
        </div>
        <iframe 
          src={`${pdfPreviewLink}?embedded=true`} 
          class="w-full h-[600px]"
          frameborder="0"
          allow="autoplay"
        ></iframe>
      </div>

      <!-- Download Options -->
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white border border-zinc-200 rounded-xl p-6 text-center">
          <div class="w-12 h-12 bg-black rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
            </svg>
          </div>
          <h3 class="font-bold text-black text-lg mb-2">Preview Online</h3>
          <p class="text-zinc-500 text-sm mb-4">Read the full e-book in your browser</p>
          <a 
            href={pdfPreviewLink}
            target="_blank"
            class="inline-block bg-blue-600 text-white px-6 py-2 rounded-lg font-semibold hover:bg-blue-700 transition-all"
          >
            Read Online →
          </a>
        </div>

        <div class="bg-white border border-zinc-200 rounded-xl p-6 text-center">
          <div class="w-12 h-12 bg-black rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
          </div>
          <h3 class="font-bold text-black text-lg mb-2">Download PDF</h3>
          <p class="text-zinc-500 text-sm mb-4">Save to your device and read offline</p>
          <a 
            href={pdfDownloadLink}
            class="inline-block bg-black text-white px-6 py-2 rounded-lg font-semibold hover:bg-zinc-800 transition-all"
          >
            Download PDF →
          </a>
        </div>
      </div>

      
      <!-- What's Inside -->
      <div class="mt-12 bg-zinc-50 rounded-xl p-8">
        <h2 class="text-2xl font-bold text-center mb-6">What's Inside This E-book</h2>
        <div class="grid md:grid-cols-2 gap-4">
          <ul class="space-y-2">
            <li class="flex items-center gap-2"><span class="text-green-600">✓</span> The 5 Stages of Business Growth</li>
            <li class="flex items-center gap-2"><span class="text-green-600">✓</span> Legal Foundation & CAC Registration</li>
            <li class="flex items-center gap-2"><span class="text-green-600">✓</span> Protecting Your Brand with Trademarks</li>
            <li class="flex items-center gap-2"><span class="text-green-600">✓</span> Building a Premium Brand</li>
          </ul>
          <ul class="space-y-2">
            <li class="flex items-center gap-2"><span class="text-green-600">✓</span> Digital Presence That Converts</li>
            <li class="flex items-center gap-2"><span class="text-green-600">✓</span> Systems That Scale (BizOS)</li>
            <li class="flex items-center gap-2"><span class="text-green-600">✓</span> Funding Options for Nigerian Businesses</li>
            <li class="flex items-center gap-2"><span class="text-green-600">✓</span> Your 90-Day Growth Action Plan</li>
          </ul>
        </div>
      </div>
    </div>
  </Container>