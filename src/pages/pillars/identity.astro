---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { Picture } from "astro:assets";
import identityHero from "@/assets/pillars-image/hero-identity.png";

const identityProjects = [
  {
    name: "OTP Global Limited",
    tagline: "Corporate Identity & Collateral Management",
    description: "Vobels manages the visual touchpoints for OTP Global. This includes high-end flyer designs, corporate presentations, and brand consistency across their international operations.",
    impact: "Created a unified, professional visual language that aligns with their global logistics and trade status.",
    driveLink: "YOUR_GOOGLE_DRIVE_URL_HERE" // Replace with your link
  },
  {
    name: "BizOS Interface Design",
    tagline: "SME-Focused Product Identity",
    description: "Designed the visual identity and user interface for BizOS. The goal was to take complex bookkeeping data and present it in a clean, minimalist 'Quiet Tech' aesthetic.",
    impact: "Transformed a complex tool into an intuitive, premium-feeling platform for business owners.",
  },
  {
    name: "Vobels Venture Studio",
    tagline: "The 'Quiet Luxury' Corporate Brand",
    description: "Our own identity was built to signal authority, minimalism, and precision. We use a monochrome-focused palette to focus attention on structural clarity.",
    impact: "Established Vobels as a premium partner in the Lagos and international business ecosystem.",
  }
];
---

<Layout title="Business Design & Identity | Vobels">
  <Container>
    <div class="mt-16 grid lg:grid-cols-2 gap-12 items-center">
      <div class="reveal-content">
        <span class="text-xs uppercase tracking-[0.3em] text-zinc-400">Pillar 02</span>
        <h1 class="text-5xl font-bold mt-4 mb-6 tracking-tight text-black">Business Design & Identity</h1>
        <p class="text-xl text-zinc-600 font-light leading-relaxed mb-8">
          Identity is more than a logo; it is the visual and strategic proof of your business's value. 
          Vobels designs the bridge between your operations and your customer’s perception.
        </p>
        
        <div class="grid gap-8">
          <div class="flex gap-4">
            <div class="flex-none w-1 h-12 bg-black"></div>
            <div>
              <h3 class="font-bold text-lg uppercase tracking-tight">Brand Naming & Positioning</h3>
              <p class="text-zinc-500">Developing a name and a voice that carves out a distinct space in the market.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="flex-none w-1 h-12 bg-zinc-200"></div>
            <div>
              <h3 class="font-bold text-lg uppercase tracking-tight">Full Visual Identity</h3>
              <p class="text-zinc-500">Logo systems, color palettes, and typography that communicate authority and trust.</p>
            </div>
          </div>
        </div>

        <div class="mt-12">
          <a href="#design-portal" class="bg-black text-white px-10 py-4 rounded-full uppercase tracking-widest text-xs font-bold hover:bg-zinc-800 transition-all">
            Design Your Authority
          </a>
        </div>
      </div>

      <div class="reveal-content">
        <Picture 
          src={identityHero} 
          alt="Vobels Business Design and Identity Visualization" 
          class="rounded-3xl shadow-2xl border border-zinc-100" 
        />
      </div>
    </div>

    <div class="mt-32">
      <div class="mb-12">
        <h2 class="text-3xl font-bold uppercase tracking-tighter">Some Projects We Did</h2>
        <p class="text-zinc-500 mt-2">Visual and strategic identities that command market attention.</p>
      </div>

      <div class="grid gap-6">
        {identityProjects.map((project) => (
          <div class="group border border-zinc-100 rounded-[2rem] overflow-hidden bg-white hover:border-zinc-300 transition-all p-8 md:p-10">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="text-2xl font-bold">{project.name}</h3>
                <p class="text-zinc-400 font-medium">{project.tagline}</p>
              </div>
            </div>

            <details class="mt-6 group/details">
              <summary class="list-none cursor-pointer flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-zinc-500 hover:text-black transition-colors">
                <span class="group-open/details:rotate-90 transition-transform">→</span> Brand Case Study
              </summary>
              <div class="mt-6 text-zinc-600 leading-relaxed grid md:grid-cols-2 gap-8 animate-in slide-in-from-top-2">
                <div>
                  <p>{project.description}</p>
                  {project.driveLink && (
                    <a href={project.driveLink} target="_blank" class="inline-block mt-4 text-xs font-bold text-black underline underline-offset-4">
                      View Design Assets (Google Drive)
                    </a>
                  )}
                </div>
                <div class="bg-zinc-50 p-6 rounded-2xl">
                   <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 block mb-2">The Impact</span>
                   <p class="text-sm font-semibold text-black">{project.impact}</p>
                </div>
              </div>
            </details>
          </div>
        ))}
      </div>
    </div>

    <div id="design-portal" class="mt-32 max-w-4xl mx-auto bg-white border border-zinc-200 p-8 md:p-16 rounded-[2.5rem] shadow-xl mb-20">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold uppercase tracking-tighter">Ready for your brand design</h2>
            <p class="text-zinc-500 mt-2">Brief us on your vision to begin the creative architecture.</p>
        </div>

        <form id="identityIntake" action="https://formspree.io/f/YOUR_ID" method="POST" class="space-y-8">
            <div class="p-6 bg-zinc-50 rounded-2xl border border-zinc-100">
                <label class="block text-xs font-bold uppercase tracking-widest mb-4 text-black">What is the status of the brand?</label>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" id="brandSelector">
                    <button type="button" data-value="new" class="brand-btn border-2 border-zinc-200 p-4 rounded-xl text-left hover:border-black transition-all bg-white font-semibold">
                        New Brand <span class="block text-xs font-normal text-zinc-400">Needs naming, logo, and core identity</span>
                    </button>
                    <button type="button" data-value="rebrand" class="brand-btn border-2 border-zinc-200 p-4 rounded-xl text-left hover:border-black transition-all bg-white font-semibold">
                        Rebrand / Upgrade <span class="block text-xs font-normal text-zinc-400">Existing business looking for maturity</span>
                    </button>
                </div>
                <input type="hidden" name="project_scope" id="selectedScope" required />
            </div>

            <div id="briefContent" class="hidden space-y-6">
                <div>
                    <label class="block text-xs font-bold uppercase mb-2">Industry / Sector</label>
                    <input type="text" name="industry" required class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border" placeholder="e.g. Real Estate, Fintech, Logistics" />
                </div>
                <div id="newBrandFields" class="hidden">
                    <label class="block text-xs font-bold uppercase mb-2">Do you have a name, or do you need Vobels to name the brand?</label>
                    <select name="naming_need" class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border">
                        <option>I have a name already</option>
                        <option>I need Vobels to handle Naming & Positioning</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase mb-2">Primary Goal of this Project</label>
                    <select name="primary_goal" class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border">
                        <option>Attract High-End Clients</option>
                        <option>Raise Investment / Pitch Ready</option>
                        <option>Professionalize Operations</option>
                        <option>Market Entry (New Product)</option>
                    </select>
                </div>
                <div class="grid md:grid-cols-2 gap-6 pt-6 border-t border-zinc-100">
                    <div>
                        <label class="block text-xs font-bold uppercase mb-2">Contact Name</label>
                        <input type="text" name="client_name" required class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase mb-2">WhatsApp Number</label>
                        <input type="tel" name="whatsapp" required class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border" placeholder="+234..." />
                    </div>
                </div>
                <button type="submit" class="w-full bg-black text-white font-bold py-5 rounded-full uppercase tracking-widest text-sm hover:scale-[1.02] active:scale-95 transition-all shadow-lg">
                    Initiate Brand Strategy Session
                </button>
            </div>
        </form>
        <div class="mt-6 pt-6 border-t border-zinc-100 text-center">
        <a href="/business-pricing#identity" class="text-sm text-zinc-500 hover:text-black underline underline-offset-4 inline-flex items-center gap-1">
            → Need only specific services? View individual pricing
        </a>
        </div>
    </div>

    <div class="mt-32 p-12 bg-black rounded-[2rem] text-white text-center">
      <h2 class="text-3xl font-bold mb-6">The Outcome</h2>
      <blockquote class="text-2xl font-light italic max-w-3xl mx-auto border-l-4 border-zinc-700 pl-8 text-left">
        "An idea transformed into a real, credible, and recognizable business asset that commands a premium in the marketplace."
      </blockquote>
      <div class="mt-10 text-sm uppercase tracking-[.4em] text-zinc-500">Idea level > Maturity</div>
    </div>

  </Container>
</Layout>

<script is:inline>
  const btns = document.querySelectorAll('.brand-btn');
  const scopeInput = document.getElementById('selectedScope');
  const briefDiv = document.getElementById('briefContent');
  const newFields = document.getElementById('newBrandFields');

  btns.forEach(btn => {
      btn.addEventListener('click', () => {
          btns.forEach(b => b.classList.replace('border-black', 'border-zinc-200'));
          const val = btn.getAttribute('data-value');
          scopeInput.value = val;
          btn.classList.replace('border-zinc-200', 'border-black');
          
          briefDiv.classList.remove('hidden');
          if(val === 'new') {
              newFields.classList.remove('hidden');
          } else {
              newFields.classList.add('hidden');
          }
      });
  });
</script>