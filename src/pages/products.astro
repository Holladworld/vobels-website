---
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";
import { Icon } from "astro-icon/components";

const products = [
  {
    name: "Vobels Flipbook",
    status: "available",
    description: "Transform your PDFs into stunning, interactive flipbooks with realistic page-flipping experience.",
    features: [
      "Interactive page flipping",
      "Shareable links",
      "Mobile responsive",
      "Fullscreen mode",
      "Analytics dashboard",
      "Custom branding"
    ],
    link: "/flipbook",
    cta: "Try Flipbook →",
    icon: "bx:book-open"
  },
  {
    name: "BizOS",
    status: "available",
    description: "Complete business operating system for modern enterprises. Streamline operations and scale efficiently.",
    features: [
      "Business process automation",
      "Team collaboration tools",
      "Real-time analytics",
      "Custom workflows",
      "Integration ready",
      "Enterprise security"
    ],
    link: "https://bizos.higroups.com",
    cta: "Launch BizOS →",
    icon: "bx:grid-alt"
  },
  {
    name: "AI Business Assistant",
    status: "coming",
    description: "Intelligent AI-powered assistant for data-driven decisions and automated customer support.",
    features: [
      "Smart document processing",
      "Customer support automation",
      "Predictive analytics",
      "Natural language queries",
      "Workflow automation",
      "24/7 intelligent support"
    ],
    link: "#",
    cta: "Notify Me →",
    icon: "bx:bot"
  },
  {
    name: "E-commerce Suite",
    status: "coming",
    description: "Complete e-commerce solution with inventory management and multi-channel selling.",
    features: [
      "Inventory management",
      "Payment integration",
      "Multi-channel selling",
      "Customer analytics",
      "Order tracking",
      "Marketing tools"
    ],
    link: "#",
    cta: "Join Waitlist →",
    icon: "bx:cart-alt"
  },
  {
    name: "Analytics Dashboard",
    status: "coming",
    description: "Comprehensive business intelligence platform with real-time dashboards and insights.",
    features: [
      "Real-time dashboards",
      "Custom reports",
      "Predictive insights",
      "Data visualization",
      "Export capabilities",
      "Team sharing"
    ],
    link: "#",
    cta: "Subscribe →",
    icon: "bx:bar-chart-alt-2"
  }
];
---

<Layout title="Products | Vobels Limited" description="Explore Vobels products including Flipbook, BizOS, and upcoming innovations.">
  <Container>
    <!-- Hero Section -->
    <div class="mt-16 text-center max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-black tracking-tighter">
        Our Products
      </h1>
      <p class="text-xl text-zinc-600 mt-4">
        Innovative solutions to transform your business operations
      </p>
    </div>

    <!-- Products Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mt-16">
      {products.map((product, index) => (
        <div class={`bg-white border rounded-2xl p-6 hover:shadow-lg transition-all relative ${product.status === 'coming' ? 'border-zinc-200' : 'border-zinc-200'}`}>
          
          {product.status === 'available' && (
            <span class="absolute top-4 right-4 bg-green-600 text-white text-xs font-bold px-3 py-1 rounded-full">
              Available
            </span>
          )}
          {product.status === 'coming' && (
            <span class="absolute top-4 right-4 bg-zinc-500 text-white text-xs font-bold px-3 py-1 rounded-full">
              Coming Soon
            </span>
          )}
          
          <div class="w-12 h-12 bg-black rounded-full flex items-center justify-center mb-4">
            <Icon name={product.icon} class="w-6 h-6 text-white" />
          </div>
          
          <h2 class="text-xl font-bold text-black mb-2">
            {product.name}
          </h2>
          
          <p class="text-zinc-500 text-sm leading-relaxed mb-4">
            {product.description}
          </p>
          
          <ul class="space-y-1 mb-6">
            {product.features.slice(0, 4).map((feature) => (
              <li class="flex items-center gap-2 text-sm text-zinc-600">
                <svg class="w-3 h-3 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                {feature}
              </li>
            ))}
            {product.features.length > 4 && (
              <li class="text-sm text-zinc-400">+ {product.features.length - 4} more features</li>
            )}
          </ul>
          
          {product.status === 'available' && (
            <a 
              href={product.link} 
              class="block text-center bg-black text-white py-3 rounded-lg font-medium hover:bg-zinc-800 transition-all"
            >
              {product.cta}
            </a>
          )}
          
          {product.status === 'coming' && (
            <button 
              data-product={product.name}
              class="notify-btn block w-full bg-zinc-100 text-black py-3 rounded-lg font-medium hover:bg-zinc-200 transition-all"
            >
              {product.cta}
            </button>
          )}
        </div>
      ))}
    </div>

    <!-- Flipbook Demo Section -->
    <div class="mt-20 bg-zinc-50 rounded-2xl p-8 border border-zinc-200">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-2xl font-bold text-black mb-4">See Flipbook in Action</h2>
          <p class="text-zinc-600 mb-6">
            Watch how your PDFs transform into beautiful, interactive flipbooks. Perfect for 
            catalogs, portfolios, ebooks, and business proposals.
          </p>
          <ul class="space-y-2 mb-8">
            <li class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Upload PDF, get flipbook in minutes
            </li>
            <li class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Share via link or embed on website
            </li>
            <li class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Track views and engagement
            </li>
          </ul>
          <a href="/flipbook" class="inline-block bg-black text-white px-6 py-3 rounded-lg font-medium hover:bg-zinc-800 transition-all">
            Try Flipbook Free →
          </a>
        </div>
        <div class="bg-black rounded-xl p-4 text-center">
          <div class="bg-white rounded-lg p-8 text-center">
            <Icon name="bx:book-open" class="w-16 h-16 text-black mx-auto mb-4" />
            <p class="text-zinc-500 text-sm">Interactive Flipbook Preview</p>
            <p class="text-zinc-400 text-xs mt-2">Click to see how it works →</p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="mt-20 mb-20 bg-black rounded-2xl p-12 text-center text-white">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Ready to Transform Your Business?</h2>
      <p class="text-zinc-300 mb-8 max-w-2xl mx-auto">
        Get started with Vobels products today. Free trials available for all available products.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-block bg-white text-black px-8 py-3 rounded-lg font-medium hover:bg-zinc-100 transition-all">
          Contact Sales →
        </a>
        <a href="/flipbook" class="inline-block border border-white text-white px-8 py-3 rounded-lg font-medium hover:bg-white/10 transition-all">
          Try Flipbook Free
        </a>
      </div>
    </div>
  </Container>

  <!-- Toast Notification -->
  <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden">
    <div class="flex items-center gap-3 px-5 py-3 rounded-xl shadow-lg bg-white border">
      <span id="toast-icon"></span>
      <span id="toast-message" class="text-sm font-medium"></span>
    </div>
  </div>

  <!-- Modal for Email Collection -->
  <div id="emailModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-2xl p-6 max-w-md w-full mx-4">
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-xl font-bold text-black">Get Notified</h3>
        <button id="closeModalBtn" class="text-zinc-400 hover:text-black">&times;</button>
      </div>
      <p id="modalProductName" class="text-zinc-600 mb-4">Enter your email to be notified when this product launches.</p>
      <input type="email" id="modalEmail" placeholder="you@example.com" class="w-full px-4 py-2 border border-zinc-300 rounded-lg mb-4 focus:outline-none focus:ring-2 focus:ring-black" />
      <button id="submitNotifyBtn" class="w-full bg-black text-white py-3 rounded-lg font-medium hover:bg-zinc-800 transition-all">Notify Me</button>
    </div>
  </div>

  <style is:inline>
    @keyframes spin { to { transform: rotate(360deg); } }
    .animate-spin { animation: spin 1s linear infinite; }
  </style>

  <script is:inline>
    // Toast notification function
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      const toastIcon = document.getElementById('toast-icon');
      const toastMessage = document.getElementById('toast-message');
      const toastDiv = toast.querySelector('div');

      toastDiv.classList.remove('border-green-200', 'bg-green-50', 'border-red-200', 'bg-red-50', 'border-amber-200', 'bg-amber-50');
      toastMessage.classList.remove('text-green-800', 'text-red-800', 'text-amber-800');

      if (type === 'success') {
        toastIcon.innerHTML = '<svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
        toastDiv.classList.add('border-green-200', 'bg-green-50');
        toastMessage.classList.add('text-green-800');
      } else if (type === 'error') {
        toastIcon.innerHTML = '<svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>';
        toastDiv.classList.add('border-red-200', 'bg-red-50');
        toastMessage.classList.add('text-red-800');
      } else {
        toastIcon.innerHTML = '<svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>';
        toastDiv.classList.add('border-amber-200', 'bg-amber-50');
        toastMessage.classList.add('text-amber-800');
      }

      toastMessage.textContent = message;
      toast.classList.remove('hidden');

      setTimeout(() => {
        toast.classList.add('hidden');
      }, 3000);
    }

    // Modal handling
    let currentProduct = '';
    const modal = document.getElementById('emailModal');
    const modalProductName = document.getElementById('modalProductName');
    const modalEmail = document.getElementById('modalEmail');
    const submitBtn = document.getElementById('submitNotifyBtn');
    const closeModalBtn = document.getElementById('closeModalBtn');

    function openModal(productName) {
      currentProduct = productName;
      modalProductName.textContent = `Enter your email to be notified when ${productName} launches.`;
      modalEmail.value = '';
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      modalEmail.focus();
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    closeModalBtn?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // Handle notification submission
    async function submitNotification(email, productName) {
      try {
        const response = await fetch('/api/capture-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: email,
            businessType: "Product Interest",
            source: "products_page",
            product: productName,
            timestamp: new Date().toISOString()
          })
        });

        const data = await response.json();
        
        if (response.ok && data.success) {
          showToast(`Thanks! We'll notify you when ${productName} launches.`, 'success');
          closeModal();
        } else {
          showToast(data.error || 'Something went wrong. Please try again.', 'error');
        }
      } catch (err) {
        console.error('Error:', err);
        showToast('Network error. Please try again.', 'error');
      }
    }

    // Attach click handlers to all notify buttons
    document.querySelectorAll('.notify-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const productName = btn.getAttribute('data-product');
        openModal(productName);
      });
    });

    // Handle submit
    submitBtn?.addEventListener('click', async () => {
      const email = modalEmail.value.trim();
      
      if (!email) {
        showToast('Please enter your email address.', 'warning');
        modalEmail.focus();
        return;
      }
      
      if (!email.includes('@') || !email.includes('.')) {
        showToast('Please enter a valid email address.', 'warning');
        modalEmail.focus();
        return;
      }
      
      await submitNotification(email, currentProduct);
    });

    // Allow Enter key to submit
    modalEmail?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        submitBtn.click();
      }
    });
  </script>
</Layout>