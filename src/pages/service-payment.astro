---

<Layout title="Service Pricing | Vobels Limited">
  <!-- TOP BANNER SLIDER - CHANGE THESE h-[100px] AND md:h-[120px] VALUES TO MAKE SMALLER -->
  <div class="relative overflow-hidden mt-5">
    <div id="topSlider" class="relative h-[60px] md:h-[80px]">
      {bannerImages.map((img, index) => (
        <div 
          id={`topSlide-${index}`}
          class="absolute inset-0 bg-cover bg-center transition-opacity duration-500 rounded-2xl mx-4"
          style={`background-image: linear-gradient(to right, rgba(0,0,0,0.7), rgba(0,0,0,0.5)), url('${img}'); opacity: ${index === 0 ? 1 : 0};`}
        >
          <div class="h-full flex flex-col items-center justify-center text-center px-4">
            <div class="max-w-2xl">
              <svg class="w-5 h-5 text-white mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
              <h2 class="text-xs md:text-base font-bold text-white mb-1">
                Need Multiple Services?
              </h2>
              <p class="text-[10px] md:text-xs text-zinc-200 mb-1.5">
                Get a Complete Business Solution
              </p>
              <a 
                href="/contact" 
                class="inline-flex items-center gap-1 bg-white text-black px-3 py-0.5 rounded-full font-semibold hover:bg-zinc-100 transition-all text-[10px] md:text-xs"
              >
                <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                </svg>
                Contact
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Slider Controls Top -->
    <button id="prevSlide" class="absolute left-6 top-1/2 -translate-y-1/2 bg-white/20 hover:bg-white/40 p-1 rounded-full transition-all z-10">
      <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>
    <button id="nextSlide" class="absolute right-6 top-1/2 -translate-y-1/2 bg-white/20 hover:bg-white/40 p-1 rounded-full transition-all z-10">
      <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </button>
    
    <!-- Dots Top -->
    <div class="absolute bottom-1 left-1/2 -translate-x-1/2 flex gap-1 z-10">
      {bannerImages.map((_, index) => (
        <button 
          id={`topDot-${index}`}
          class={`top-dot h-1 rounded-full transition-all ${index === 0 ? 'bg-white w-3' : 'bg-white/50 w-1'}`}
          data-index={index}
        ></button>
      ))}
    </div>
  </div>

  <Container>
    <div class="mt-8 text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-black text-black tracking-tighter">Service Pricing</h1>
      <p class="mt-4 text-zinc-500 max-w-2xl mx-auto">
        Transparent fixed pricing for our core services. Select any service to make payment.
      </p>
    </div>

    <!-- Quick Navigation -->
    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <a href="#formation" class="text-xs bg-zinc-100 hover:bg-black hover:text-white px-4 py-2 rounded-full transition-all">Formation</a>
      <a href="#identity" class="text-xs bg-zinc-100 hover:bg-black hover:text-white px-4 py-2 rounded-full transition-all">Identity</a>
      <a href="#operations" class="text-xs bg-zinc-100 hover:bg-black hover:text-white px-4 py-2 rounded-full transition-all">Operations</a>
      <a href="#technology" class="text-xs bg-zinc-100 hover:bg-black hover:text-white px-4 py-2 rounded-full transition-all">Technology</a>
      <a href="#global" class="text-xs bg-zinc-100 hover:bg-black hover:text-white px-4 py-2 rounded-full transition-all">Global</a>
      <a href="#expansion" class="text-xs bg-zinc-100 hover:bg-black hover:text-white px-4 py-2 rounded-full transition-all">Expansion</a>
    </div>

    <!-- Multiple Services Banner -->
    <div class="bg-gradient-to-r from-black to-zinc-800 text-white p-6 rounded-2xl mb-12 text-center">
      <p class="text-lg font-semibold">Need multiple services or a complete business solution?</p>
      <p class="text-sm text-zinc-300 mt-1 mb-4">Our consulting packages are designed for end-to-end business transformation.</p>
      <a href="/pricing" class="inline-block bg-white text-black px-6 py-2 rounded-full text-sm font-bold hover:bg-zinc-100 transition-all">
        View Consulting Packages →
      </a>
    </div>

    {Object.entries(services).map(([key, section]) => (
      <div id={section.id} class="mb-16 scroll-mt-24">
        <h2 class="text-2xl font-bold mb-6 pb-2 border-b-2 border-black inline-block">
          {section.title}
        </h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          {section.items.map((item) => (
            <div class="border border-zinc-200 rounded-xl p-5 hover:shadow-lg transition-all bg-white">
              <h3 class="font-semibold text-black mb-2">{item.name}</h3>
              
              {/* Show price or dropdown if hasOptions */}
              {item.hasOptions ? (
                <div class="mb-4">
                  <select 
                    id={`select-${item.id}`}
                    class="w-full p-2 border border-zinc-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-black mb-2"
                    data-service-id={item.id}
                    data-service-name={item.name}
                  >
                    <option value="">Select category</option>
                    {item.options.map((opt) => (
                      <option value={opt.price} data-price={opt.price}>
                        {opt.name} - ₦{opt.price.toLocaleString()}
                      </option>
                    ))}
                  </select>
                  <p class="text-xs text-zinc-400" id={`desc-${item.id}`}></p>
                  <a 
                    href="#"
                    id={`pay-${item.id}`}
                    class="pay-btn hidden block text-center bg-black text-white py-2 rounded-lg transition-all text-sm font-medium hover:bg-zinc-800 mt-2"
                    data-base-name={item.name}
                  >
                    Pay for this service →
                  </a>
                </div>
              ) : (
                <>
                  <p class="text-2xl font-bold text-black mb-4">
                    {item.price === "Varies" ? item.price : formatPrice(item.price, item.currency)}
                  </p>
                  
                  {/* Show documents if they exist */}
                  {item.documents && (
                    <details class="mb-4 text-xs">
                      <summary class="cursor-pointer text-zinc-500 hover:text-black font-medium">
                        What's included →
                      </summary>
                      <ul class="mt-2 space-y-1 pl-4">
                        {item.documents.map((doc) => (
                          <li class="text-zinc-600 text-xs flex items-start gap-1">
                            <span class="text-green-600">✓</span> {doc}
                          </li>
                        ))}
                      </ul>
                    </details>
                  )}
                  
                  <a 
                    href={item.isVariable ? "/contact" : `/service-payment?service=${item.id}&amount=${typeof item.price === 'number' ? item.price : 0}&currency=${item.currency}&name=${encodeURIComponent(item.name)}`}
                    class={`block text-center py-2 rounded-lg transition-all text-sm font-medium ${item.isVariable ? 'bg-zinc-600 hover:bg-zinc-700 text-white' : 'bg-black hover:bg-zinc-800 text-white'}`}
                  >
                    {item.isVariable ? "Request Quote →" : "Pay for this service →"}
                  </a>
                </>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}
  </Container>

  <!-- BOTTOM BANNER SLIDER - CHANGE THESE h-[100px] AND md:h-[120px] VALUES TO MAKE SMALLER -->
  <div class="relative overflow-hidden mt-10 mb-10">
    <div id="bottomSlider" class="relative h-[20px] md:h-[40px]">
      {bannerImages.map((img, index) => (
        <div 
          id={`bottomSlide-${index}`}
          class="absolute inset-0 bg-cover bg-center transition-opacity duration-500 rounded-2xl mx-4"
          style={`background-image: linear-gradient(to right, rgba(0,0,0,0.7), rgba(0,0,0,0.5)), url('${img}'); opacity: ${index === 0 ? 1 : 0};`}
        >
          <div class="h-full flex flex-col items-center justify-center text-center px-4">
            <div class="max-w-2xl">
              <svg class="w-5 h-5 text-white mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <h2 class="text-xs md:text-base font-bold text-white mb-1">
                Still Can't Find It?
              </h2>
              <p class="text-[10px] md:text-xs text-zinc-200 mb-1.5">
                Get a custom solution for your needs
              </p>
              <a 
                href="/contact" 
                class="inline-flex items-center gap-1 bg-white text-black px-3 py-0.5 rounded-full font-semibold hover:bg-zinc-100 transition-all text-[10px] md:text-xs"
              >
                <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Custom Quote
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Slider Controls Bottom -->
    <button id="prevSlideBottom" class="absolute left-6 top-1/2 -translate-y-1/2 bg-white/20 hover:bg-white/40 p-1 rounded-full transition-all z-10">
      <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>
    <button id="nextSlideBottom" class="absolute right-6 top-1/2 -translate-y-1/2 bg-white/20 hover:bg-white/40 p-1 rounded-full transition-all z-10">
      <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </button>
    
    <!-- Dots Bottom -->
    <div class="absolute bottom-1 left-1/2 -translate-x-1/2 flex gap-1 z-10">
      {bannerImages.map((_, index) => (
        <button 
          id={`bottomDot-${index}`}
          class={`bottom-dot h-1 rounded-full transition-all ${index === 0 ? 'bg-white w-3' : 'bg-white/50 w-1'}`}
          data-index={index}
        ></button>
      ))}
    </div>
  </div>
</Layout>

<script is:inline>
  // Handle NAFDAC dropdown selections
  const selects = document.querySelectorAll('select[data-service-id]');
  
  selects.forEach(select => {
    const serviceId = select.getAttribute('data-service-id');
    const payBtn = document.getElementById(`pay-${serviceId}`);
    const descEl = document.getElementById(`desc-${serviceId}`);
    const serviceName = select.getAttribute('data-service-name');
    
    select.addEventListener('change', () => {
      const selectedOption = select.options[select.selectedIndex];
      const price = selectedOption.getAttribute('data-price');
      const categoryName = selectedOption.text.split(' - ')[0];
      
      if (price && payBtn) {
        payBtn.classList.remove('hidden');
        const fullName = `${serviceName} - ${categoryName}`;
        payBtn.setAttribute('href', `/service-payment?service=${serviceId}&amount=${price}&currency=NGN&name=${encodeURIComponent(fullName)}`);
        if (descEl) {
          descEl.textContent = selectedOption.getAttribute('data-description') || '';
        }
      } else if (payBtn) {
        payBtn.classList.add('hidden');
      }
    });
  });

  // TOP SLIDER FUNCTIONALITY
  let topCurrentIndex = 0;
  const topSlides = document.querySelectorAll('[id^="topSlide-"]');
  const topDots = document.querySelectorAll('.top-dot');
  const totalSlides = topSlides.length;

  function showTopSlide(index) {
    topSlides.forEach((slide, i) => {
      slide.style.opacity = i === index ? '1' : '0';
    });
    topDots.forEach((dot, i) => {
      if (i === index) {
        dot.classList.add('bg-white', 'w-3');
        dot.classList.remove('bg-white/50', 'w-1');
      } else {
        dot.classList.remove('bg-white', 'w-3');
        dot.classList.add('bg-white/50', 'w-1');
      }
    });
  }

  function nextTopSlide() {
    topCurrentIndex = (topCurrentIndex + 1) % totalSlides;
    showTopSlide(topCurrentIndex);
  }

  function prevTopSlide() {
    topCurrentIndex = (topCurrentIndex - 1 + totalSlides) % totalSlides;
    showTopSlide(topCurrentIndex);
  }

  let topInterval = setInterval(nextTopSlide, 5000);

  document.getElementById('nextSlide')?.addEventListener('click', () => {
    clearInterval(topInterval);
    nextTopSlide();
    topInterval = setInterval(nextTopSlide, 5000);
  });

  document.getElementById('prevSlide')?.addEventListener('click', () => {
    clearInterval(topInterval);
    prevTopSlide();
    topInterval = setInterval(nextTopSlide, 5000);
  });

  topDots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(topInterval);
      topCurrentIndex = i;
      showTopSlide(topCurrentIndex);
      topInterval = setInterval(nextTopSlide, 5000);
    });
  });

  // BOTTOM SLIDER FUNCTIONALITY
  let bottomCurrentIndex = 0;
  const bottomSlides = document.querySelectorAll('[id^="bottomSlide-"]');
  const bottomDots = document.querySelectorAll('.bottom-dot');
  const bottomTotalSlides = bottomSlides.length;

  function showBottomSlide(index) {
    bottomSlides.forEach((slide, i) => {
      slide.style.opacity = i === index ? '1' : '0';
    });
    bottomDots.forEach((dot, i) => {
      if (i === index) {
        dot.classList.add('bg-white', 'w-3');
        dot.classList.remove('bg-white/50', 'w-1');
      } else {
        dot.classList.remove('bg-white', 'w-3');
        dot.classList.add('bg-white/50', 'w-1');
      }
    });
  }

  function nextBottomSlide() {
    bottomCurrentIndex = (bottomCurrentIndex + 1) % bottomTotalSlides;
    showBottomSlide(bottomCurrentIndex);
  }

  function prevBottomSlide() {
    bottomCurrentIndex = (bottomCurrentIndex - 1 + bottomTotalSlides) % bottomTotalSlides;
    showBottomSlide(bottomCurrentIndex);
  }

  let bottomInterval = setInterval(nextBottomSlide, 5000);

  document.getElementById('nextSlideBottom')?.addEventListener('click', () => {
    clearInterval(bottomInterval);
    nextBottomSlide();
    bottomInterval = setInterval(nextBottomSlide, 5000);
  });

  document.getElementById('prevSlideBottom')?.addEventListener('click', () => {
    clearInterval(bottomInterval);
    prevBottomSlide();
    bottomInterval = setInterval(nextBottomSlide, 5000);
  });

  bottomDots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(bottomInterval);
      bottomCurrentIndex = i;
      showBottomSlide(bottomCurrentIndex);
      bottomInterval = setInterval(nextBottomSlide, 5000);
    });
  });
</script>