// Format price display based on currency
function formatPrice(price, currency) {
  if (price === "Varies") return "Varies";
  if (currency === "USD") {
    return `$${price.toLocaleString()} USD`;
  }
  return `₦${price.toLocaleString()}`;
}

// Banner images (free business-related images)
