---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { Picture } from "astro:assets";
import techHero from "@/assets/service-image/hero-technology.png"; 

const techProjects = [
  {
    name: "Siliconverse",
    tagline: "High-Performance Backend Infrastructure",
    description: "Architected the server-side logic for a high-traffic job portal. Focused on optimized data indexing and multi-layered filtering to ensure sub-second response times for thousands of concurrent users.",
    techStack: "Node.js, Python, PostgreSQL, RESTful APIs",
    metric: "Enterprise-Grade Scalability"
  },
  {
    name: "BizOS Technical Engine",
    tagline: "Proprietary Automation Architecture",
    description: "Engineered the core logic of the BizOS operating system. Developed custom bridges between financial data and automated reporting modules using Google Cloud scripts and secure API integrations.",
    techStack: "JavaScript, App Script, Cloud Functions",
    metric: "100% Automated Workflow"
  },
  {
    name: "OTP Global Logistics Tooling",
    tagline: "System Integration & Data Migration",
    description: "Managed the technical transition from legacy ERP systems to modernized cloud architecture. This involved clean data mapping, script-based migration, and custom dashboard development.",
    techStack: "ERP Management, Flectra, System Architecture",
    metric: "Zero-Downtime Migration"
  },
  {
    name: "Referlytic",
    tagline: "Influencer-to-Business SaaS Infrastructure",
    description: "Engineered the core backend architecture for the Business Owner module. Built the logic for campaign management, real-time ROI tracking, and secure partner dashboards, ensuring seamless data flow between brands and influencers.",
    techStack: "Node.js, PostgreSQL, API Orchestration, JWT Auth",
    metric: "Multi-Tenant Partner Logic"
  }
];
---

<Layout title="Digital Presence & Tech | Vobels">
  <Container>
    <div class="mt-16 grid lg:grid-cols-2 gap-12 items-center">
      <div class="reveal-content">
        <span class="text-xs uppercase tracking-[0.3em] text-zinc-400">Pillar 04</span>
        <h1 class="text-5xl font-bold mt-4 mb-6 tracking-tight text-black">Digital Presence & Tech</h1>
        <p class="text-xl text-zinc-600 font-light leading-relaxed mb-8">
          We don't just build websites; we build digital assets. Vobels engineers high-performance 
          environments that turn browsers into users and users into data-driven insights.
        </p>
        
        <div class="grid gap-8">
          <div class="flex gap-4">
            <div class="flex-none w-1 h-12 bg-black"></div>
            <div>
              <h3 class="font-bold text-lg uppercase tracking-tight">Backend & System Architecture</h3>
              <p class="text-zinc-500">Building the invisible engines that power high-speed, secure, and scalable business operations.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="flex-none w-1 h-12 bg-zinc-200"></div>
            <div>
              <h3 class="font-bold text-lg uppercase tracking-tight">Custom Software Solutions</h3>
              <p class="text-zinc-500">Tailor-made internal tools and customer-facing apps designed to solve specific business bottlenecks.</p>
            </div>
          </div>
        </div>

        <div class="mt-12">
          <a href="#tech-portal" class="bg-black text-white px-10 py-4 rounded-full uppercase tracking-widest text-xs font-bold hover:bg-zinc-800 transition-all">
            Build My Infrastructure
          </a>
        </div>
      </div>

      <div class="reveal-content">
        <Picture 
          src={techHero} 
          alt="Vobels Technical Engineering Visualization" 
          class="rounded-3xl shadow-2xl border border-zinc-100" 
        />
      </div>
    </div>

    <div class="mt-32">
      <div class="mb-12">
        <h2 class="text-3xl font-bold uppercase tracking-tighter">Engineering Case Studies</h2>
        <p class="text-zinc-500 mt-2">Where high-level code meets real-world business results.</p>
      </div>

      <div class="grid gap-8">
        {techProjects.map((project) => (
          <div class="group border border-zinc-100 rounded-[2.5rem] bg-white p-8 md:p-12 hover:border-zinc-300 transition-all shadow-sm hover:shadow-md">
            <div class="flex flex-col lg:flex-row justify-between items-start gap-8">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-4">
                  <h3 class="text-3xl font-bold">{project.name}</h3>
                </div>
                <p class="text-zinc-400 font-semibold mb-6 uppercase tracking-wider text-sm">{project.tagline}</p>
                <p class="text-zinc-600 leading-relaxed text-lg max-w-2xl mb-8">
                  {project.description}
                </p>
                
                <div class="flex flex-wrap gap-2">
                  {project.techStack.split(',').map(tech => (
                    <span class="text-[11px] font-bold uppercase bg-zinc-50 text-zinc-500 border border-zinc-200 px-4 py-1.5 rounded-full">
                      {tech.trim()}
                    </span>
                  ))}
                </div>
              </div>

              <div class="bg-black text-white p-8 rounded-3xl w-full lg:w-72 text-center flex flex-col justify-center">
                <span class="text-[10px] uppercase tracking-[0.3em] opacity-50 mb-2">Technical Status</span>
                <p class="text-xl font-bold leading-tight">{project.metric}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div id="tech-portal" class="mt-32 max-w-4xl mx-auto bg-white border border-zinc-200 p-8 md:p-16 rounded-[2.5rem] shadow-xl mb-20">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold uppercase tracking-tighter">Initiate Technical Brief</h2>
            <p class="text-zinc-500 mt-2">Provide the specifications for your next digital asset.</p>
        </div>

        <form action="https://formspree.io/f/YOUR_ID" method="POST" class="space-y-6">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label class="block text-xs font-bold uppercase mb-2">Primary Need</label>
                <select name="tech_need" class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border appearance-none">
                  <option>Custom Web Application</option>
                  <option>Internal Business Tool / BizOS</option>
                  <option>API & System Integration</option>
                  <option>Architecture Audit / Consulting</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-bold uppercase mb-2">Expected Scale</label>
                <select name="scale" class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border appearance-none">
                  <option>Internal Team Only</option>
                  <option>1,000+ Active Users</option>
                  <option>10,000+ Active Users</option>
                  <option>Enterprise / Global</option>
                </select>
              </div>
            </div>
            
            <div>
                <label class="block text-xs font-bold uppercase mb-2">Technical Requirements</label>
                <textarea name="requirements" placeholder="Briefly describe the stack preferences or functionality needed..." rows="4" class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border"></textarea>
            </div>

            <div class="grid md:grid-cols-2 gap-6 pt-6 border-t border-zinc-100">
                <div>
                    <label class="block text-xs font-bold uppercase mb-2">Contact Name</label>
                    <input type="text" name="name" required class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border" />
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase mb-2">WhatsApp / Email</label>
                    <input type="text" name="contact" required class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border" />
                </div>
            </div>

            <button type="submit" class="w-full bg-black text-white font-bold py-5 rounded-full uppercase tracking-widest text-sm hover:bg-zinc-800 transition-all shadow-lg">
                Submit Architecture Brief
            </button>
        </form>
         <div class="mt-6 pt-6 border-t border-zinc-100 text-center">
        <a href="/business-pricing#technology" class="text-sm text-zinc-500 hover:text-black underline underline-offset-4 inline-flex items-center gap-1">
            → Need only specific services? View individual pricing
        </a>
    </div>
    </div>

    <div class="mt-32 p-12 bg-black rounded-[2rem] text-white text-center">
      <h2 class="text-3xl font-bold mb-6">The Outcome</h2>
      <blockquote class="text-2xl font-light italic max-w-3xl mx-auto border-l-4 border-zinc-700 pl-8 text-left">
        "Software that doesn't just work, but wins. We build the technological backbone that allows your vision to scale without breaking."
      </blockquote>
      <div class="mt-10 text-sm uppercase tracking-[.4em] text-zinc-500">Prototype > Scalable Asset</div>
    </div>
  </Container>
</Layout>