---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { Picture } from "astro:assets";
import growthHero from "@/assets/service-image/hero-growth.png";


const growthStrategies = [
  {
    name: "Faceless Authority Channels",
    tagline: "High-Ticket Content Strategy",
    description: "Developing automated, faceless video systems for platforms like TikTok and Instagram. We focus on luxury travel, finance, and tech niches to build massive reach without requiring a personal brand spokesperson.",
    channel: "TikTok / IG / YouTube"
  },
  {
    name: "NxPrivé Echelon Launch",
    tagline: "Luxury Market Entry Strategy",
    description: "Orchestrated the brand positioning and lead generation strategy for a luxury travel brokerage. Built the bridge between high-net-worth clients and private jet charter services.",
    channel: "Affiliate & Direct Outreach"
  },
  {
    name: "Performance Marketing",
    tagline: "Paid Traffic & ROI Optimization",
    description: "Deployment of strategic ad spend to acquire users for SaaS products and service-based businesses. We focus on low customer acquisition costs (CAC) and high lifetime value (LTV).",
    channel: "Meta / Google Ads"
  }
];
---

<Layout title="Growth & Expansion | Vobels">
  <Container>
    <div class="mt-16 grid lg:grid-cols-2 gap-12 items-center">
      <div class="reveal-content">
        <span class="text-xs uppercase tracking-[0.3em] text-zinc-400">Pillar 05</span>
        <h1 class="text-5xl font-bold mt-4 mb-6 tracking-tight text-black">Growth & Expansion</h1>
        <p class="text-xl text-zinc-600 font-light leading-relaxed mb-8">
          A great business hidden from the world is a tragedy. Vobels builds the distribution engines 
          that ensure your brand reaches the right eyes, in the right markets, at the right time.
        </p>
        
        <div class="grid gap-8">
          <div class="flex gap-4">
            <div class="flex-none w-1 h-12 bg-black"></div>
            <div>
              <h3 class="font-bold text-lg uppercase tracking-tight">Faceless Content Systems</h3>
              <p class="text-zinc-500">Building media assets that generate leads and authority on autopilot using advanced content automation.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="flex-none w-1 h-12 bg-zinc-200"></div>
            <div>
              <h3 class="font-bold text-lg uppercase tracking-tight">Market Entry & Ads</h3>
              <p class="text-zinc-500">Strategic deployment of capital into high-converting ad channels and new geographical markets.</p>
            </div>
          </div>
        </div>

        <div class="mt-12">
          <a href="#growth-portal" class="bg-black text-white px-10 py-4 rounded-full uppercase tracking-widest text-xs font-bold hover:bg-zinc-800 transition-all">
            Scale My Brand
          </a>
          <!-- REMOVED pricing link from here -->
        </div>
      </div>

      <div class="reveal-content">
        <Picture 
          src={growthHero} 
          alt="Vobels Growth and Scaling Visualization" 
          widths={[400, 800, 1200]}
          sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
          class="rounded-3xl shadow-2xl border border-zinc-100 w-full h-auto"
          loading="eager"
          format="avif"
        />
      </div>
    </div>

    <div class="mt-32">
      <div class="mb-12">
        <h2 class="text-3xl font-bold uppercase tracking-tighter">Growth Ecosystems</h2>
        <p class="text-zinc-500 mt-2">Turning quiet businesses into market authorities.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {growthStrategies.map((strategy) => (
          <div class="group border border-zinc-100 rounded-[2rem] bg-white p-8 hover:border-black transition-all flex flex-col justify-between shadow-sm">
            <div>
              <div class="mb-4">
                 <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">{strategy.channel}</span>
                 <h3 class="text-xl font-bold mt-1 leading-tight">{strategy.name}</h3>
              </div>
              <p class="text-zinc-500 text-sm leading-relaxed mb-6">{strategy.description}</p>
            </div>
            <div class="pt-6 border-t border-zinc-50">
               <p class="text-xs font-bold uppercase tracking-tighter text-black">{strategy.tagline}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div id="growth-portal" class="mt-32 max-w-4xl mx-auto bg-white border border-zinc-200 p-8 md:p-16 rounded-[2.5rem] shadow-xl mb-20">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold uppercase tracking-tighter">The Scaling Brief</h2>
            <p class="text-zinc-500 mt-2">Ready to move from established to dominant?</p>
        </div>

        <form action="https://formspree.io/f/YOUR_ID" method="POST" class="space-y-6">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label class="block text-xs font-bold uppercase mb-2">Primary Goal</label>
                <select name="goal" class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border appearance-none">
                  <option>New Market Entry</option>
                  <option>Lead Generation (B2B)</option>
                  <option>Content Automation / Social Reach</option>
                  <option>Revenue Scaling</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-bold uppercase mb-2">Monthly Ad Budget (Approx)</label>
                <input type="text" name="budget" placeholder="e.g. $500 - $2000" class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border" />
              </div>
            </div>
            
            <div class="grid md:grid-cols-2 gap-6 pt-6 border-t border-zinc-100">
                <div>
                    <label class="block text-xs font-bold uppercase mb-2">Contact Name</label>
                    <input type="text" name="name" required class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border" />
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase mb-2">WhatsApp / Social Link</label>
                    <input type="text" name="contact" required class="w-full bg-zinc-50 border-zinc-200 rounded-lg p-4 border" />
                </div>
            </div>

            <button type="submit" class="w-full bg-black text-white font-bold py-5 rounded-full uppercase tracking-widest text-sm hover:bg-zinc-800 transition-all">
                Initiate Scaling Session
            </button>
        </form>
        
        <!-- ✅ MOVED HERE - At the bottom of the form -->
        <div class="mt-8 pt-6 border-t border-zinc-200 text-center">
          <p class="text-sm text-zinc-500 mb-2">Need just one specific service?</p>
          <a href="/business-pricing#expansion" class="text-sm text-black hover:text-zinc-600 underline underline-offset-4 inline-flex items-center gap-1 font-medium">
            → View pricing for individual services
          </a>
        </div>
    </div>

    <div class="mt-32 p-12 bg-black rounded-[2rem] text-white text-center">
      <h2 class="text-3xl font-bold mb-6">The Outcome</h2>
      <blockquote class="text-2xl font-light italic max-w-3xl mx-auto border-l-4 border-zinc-700 pl-8 text-left">
        "Transitioning from a local presence to a global authority. We don't just find customers; we build an audience that sustains your business for the long term."
      </blockquote>
      <div class="mt-10 text-sm uppercase tracking-[.4em] text-zinc-500">Authority > Market Dominance</div>
    </div>
  </Container>
</Layout>