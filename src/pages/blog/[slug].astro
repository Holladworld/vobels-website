---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { posts, initializePosts } from "@/lib/posts-store";

const { slug } = Astro.params;

await initializePosts();

// Decode the slug to handle any URL encoding
const decodedSlug = decodeURIComponent(slug);
const post = posts.find(p => p.slug === decodedSlug);

if (!post) {
  return new Response("Post not found", { status: 404 });
}
---

<Layout 
  title={post.title} 
  description={post.snippet?.replace(/<[^>]*>/g, '') || post.title} 
  image={post.coverImage}
>
  <Container>
    <div class="mx-auto max-w-3xl mt-20">

      <div class="text-center mb-12">
        <span class="text-[11px] font-bold uppercase tracking-[0.3em] text-zinc-400">
          {post.category}
        </span>

        <h1 class="text-4xl font-bold mt-6">
          {post.title}
        </h1>

        <div class="text-sm text-zinc-400 mt-2">
          {post.author} / {new Date(post.publishDate).toDateString()}
        </div>
      </div>

      {post.coverImage && post.coverImage !== '/default-cover.jpg' && (
        <img 
          src={post.coverImage} 
          alt={post.title}
          class="rounded-2xl mb-10 w-full h-auto object-cover" 
          loading="lazy"
        />
      )}

      <!-- FIX: Proper content rendering -->
      <article class="prose prose-lg max-w-none mx-auto">
        {post.source === 'content' ? (
          // For markdown content, we need to parse it
          <Fragment set:html={post.content} />
        ) : (
          // For API content, it's already HTML or markdown
          <Fragment set:html={post.content} />
        )}
      </article>

      <div class="text-center mt-12 pt-8 border-t">
        <a href="/blog" class="text-blue-600 hover:underline">
          ← Back to all posts
        </a>
      </div>

    </div>
  </Container>
</Layout>

<style is:global>
  /* Fix markdown rendering */
  .prose h1, .prose h2, .prose h3 {
    margin-top: 2em;
    margin-bottom: 0.5em;
  }
  
  .prose p {
    margin-bottom: 1.25em;
    line-height: 1.7;
  }
  
  .prose ul, .prose ol {
    margin-top: 0.5em;
    margin-bottom: 1.25em;
    padding-left: 1.5em;
  }
  
  .prose li {
    margin-bottom: 0.25em;
  }
  
  .prose strong {
    font-weight: 700;
    color: #000;
  }
  
  .prose a {
    color: #2563eb;
    text-decoration: underline;
  }
</style>