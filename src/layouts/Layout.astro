---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  image?: string; // Add optional image prop for blog posts
}

const { title, description, image } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

// Logic: Use the passed image (from Unsplash), or default to your local opengraph.jpg
const resolvedImageWithDomain = image?.startsWith("http")
  ? image 
  : new URL(image || "/opengraph.jpg", Astro.site).toString();

const makeTitle = title
  ? title + " | " + "Vobels Limited"
  : "Vobels Limited - Business Enablement & Growth Partner";

const makeDescription = description 
  ? description 
  : "Vobels Limited is a full-service development and growth firm building businesses from idea to maturity.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <SEO
      title={makeTitle}
      description={makeDescription}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        optional: {
          description: makeDescription,
          siteName: "Vobels Limited",
        },
        image: {
          alt: title || "Vobels Limited Logo",
          width: 1200,
          height: 630,
        }
      }}
      twitter={{
        card: "summary_large_image",
        site: "@vobels_limited",
        creator: "@vobels_limited",
        title: makeTitle,
        description: makeDescription,
        image: resolvedImageWithDomain,
      }}
      extend={{
        meta: [
          { name: "twitter:image", content: resolvedImageWithDomain },
          { name: "twitter:title", content: makeTitle },
          { name: "twitter:description", content: makeDescription },
        ],
      }}
    />
  </head>
  <body class="bg-white antialiased">
    <Navbar />
    <main class="reveal-content">
      <slot />
    </main>
    <Footer />

    <script>
      import { inView, animate, stagger } from "motion";

      // Smooth reveal for all sections as you scroll
      inView(".reveal-content", (element) => {
        animate(
          element,
          { opacity: [0, 1], y: [20, 0] },
          { duration: 0.8, easing: [0.17, 0.55, 0.55, 1] }
        );
      });

      // Staggered reveal for pillars/features
      inView(".grid", (element) => {
        const items = element.querySelectorAll(".flex");
        animate(
          items,
          { opacity: [0, 1], y: [20, 0] },
          { delay: stagger(0.1), duration: 0.5 }
        );
      });
    </script>
    <style is:global>
      /* Image optimization */
      img {
        content-visibility: auto;
        max-width: 100%;
        height: auto;
      }
      
      /* Smooth scrolling for the whole site */
      html {
        scroll-behavior: smooth;
      }
      
      /* Better touch scrolling on iOS */
      body {
        -webkit-overflow-scrolling: touch;
      }
      
      /* Disable text zoom on orientation change on iOS */
      @media (max-width: 640px) {
        input, select, textarea {
          font-size: 16px !important;
        }
      }
      
      /* Responsive table overflow */
      table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }
      
      @media (max-width: 640px) {
        .table-container {
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
        }
      }
      
      /* Better tap highlighting on mobile */
      a, button {
        -webkit-tap-highlight-color: rgba(0,0,0,0.1);
      }
    </style>
  </body>
</html>